---
const { title } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Grüne Vorlagen</title>
    <link rel="stylesheet" href="https://grueneat.github.io/design-system/design-system.css" />
    <style is:global>
      :root {
        /* Lokale Marken-Aliase auf DS-Tokens (Phase 0, #126).
           Lokale Namen bleiben, Werte verweisen aufs Design-System. */
        --gruen-dunkel: var(--gat-color-dunkelgruen);
        --gruen-hell: var(--gat-color-hellgruen);
        --gelb: var(--gat-color-gelb);
        --magenta: var(--gat-color-magenta);
        --bg: #fafafa;
        --text: #222;
        --muted: #666;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font: 16px/1.5 system-ui, -apple-system, sans-serif;
        color: var(--text);
        background: var(--bg);
      }
      header {
        background: var(--gruen-dunkel);
        color: white;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      header a { color: white; text-decoration: none; }
      header h1 { margin: 0; font-size: 1.4rem; }
      header nav { display: flex; gap: 1rem; flex-wrap: wrap; }
      header nav a {
        font-size: 0.95rem;
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        transition: background 0.15s, border-color 0.15s;
      }
      header nav a:hover {
        background: var(--gruen-hell);
        border-color: var(--gruen-hell);
      }
      main { max-width: 1100px; margin: 0 auto; padding: 2rem; }
      footer { color: var(--muted); padding: 2rem; text-align: center; font-size: 0.85em; }
      h1, h2, h3 { color: var(--gruen-dunkel); }
      a { color: var(--gruen-dunkel); }
    </style>
  </head>
  <body>
    <header>
      <a href={BASE} style="display: flex; align-items: center; gap: 0.75rem; text-decoration: none;">
        <img src="https://grueneat.github.io/design-system/assets/gruene-logo.svg" alt="Die Grünen" style="height: 40px; width: auto; display: block;" />
        <h1>Grüne Vorlagen NÖ</h1>
      </a>
      <nav>
        <a href={url('/')}>Galerie</a>
        <a href={url('experiments/')}>Design-Experimente</a>
        <a href={url('schriften/')}>Freie Schriften</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>Grüne NÖ · Skelett-Vorlagen für lokale Gruppen</footer>
  </body>
</html>
