---
import '../styles/app.css';
const { title } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Grüne Vorlagen</title>
    <link rel="stylesheet" href="https://grueneat.github.io/design-system/design-system.css" />
    <style is:global>
      :root {
        /* Lokale Marken-Aliase auf DS-Tokens (Phase 0, #126).
           Lokale Namen bleiben, Werte verweisen aufs Design-System. */
        --gruen-dunkel: var(--gat-color-dunkelgruen);
        --gruen-hell: var(--gat-color-hellgruen);
        --gelb: var(--gat-color-gelb);
        --magenta: var(--gat-color-magenta);
        /* Lokale Site-Aliase auf DS-Web-Tokens (Phase 2, #126).
           Alle Werte verweisen jetzt aufs DS — drift gestoppt. */
        --bg: var(--gat-web-bg);
        --text: var(--gat-web-text);
        --muted: var(--gat-web-text-mute);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font: 16px/1.5 system-ui, -apple-system, sans-serif;
        color: var(--text);
        background: var(--bg);
      }
      /* Header-Styles kommen aus dem Design-System (.gat-header --dunkel). */
      main { max-width: 1100px; margin: 0 auto; padding: 2rem; }
      footer { color: var(--muted); padding: 2rem; text-align: center; font-size: 0.85em; }
      /* Headlines opt-in via .gat-headline aus dem Design-System
         (siehe app.css). Tag-Selektor entfernt — Phase 2, #126. */
      a { color: var(--gruen-dunkel); }

      /* Subbrand-Zeile unter der Wortmarke „Vorlagen":
         macht sichtbar, dass dieses Tool aus der NÖ-Landesgruppe kommt.
         Pill „NÖ" als kleiner Akzent, Text dezenter als die Wortmarke. */
      .gat-header__brand-text {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.15rem;
        line-height: 1.1;
      }
      .gat-header__subbrand {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.78rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 0.01em;
      }
      .gat-header__subbrand-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.05rem 0.4rem;
        background: var(--gat-color-hellgruen);
        color: var(--gat-color-anthrazit, #1a1a1a);
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.4;
      }
      @media (max-width: 640px) {
        .gat-header__subbrand {
          font-size: 0.72rem;
          gap: 0.3rem;
        }
        .gat-header__subbrand-pill {
          font-size: 0.65rem;
          padding: 0.05rem 0.35rem;
        }
      }

      /* Support-Mailto rechts in der Brandbar.
         Desktop: Icon + Adresse. Mobile (<=640px): nur Icon. */
      .gat-header__support {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-left: 1rem;
        padding: 0.35rem 0.6rem;
        color: white;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: var(--gat-web-radius-control);
        font-size: 0.85rem;
        line-height: 1;
        white-space: nowrap;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .gat-header__support:hover,
      .gat-header__support:focus-visible {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.6);
        color: white;
      }
      .gat-header__support-icon {
        width: 1.1em;
        height: 1.1em;
        display: block;
        flex: none;
      }
      @media (max-width: 640px) {
        .gat-header__support {
          margin-left: 0.5rem;
          padding: 0.35rem;
        }
        .gat-header__support-label {
          /* Auf Mobil zeigen wir nur das Icon. Label bleibt fuer
             Screenreader im DOM, wird aber visuell versteckt. */
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border: 0;
        }
      }
    </style>
  </head>
  <body>
    <a class="gat-skiplink" href="#main">Zum Hauptinhalt springen</a>
    <header class="gat-header gat-header--dunkel">
      <div class="gat-header__inner">
        <a class="gat-header__brand" href={BASE}>
          <img class="gat-header__logo" src="https://grueneat.github.io/design-system/assets/gruene-logo.svg" alt="Die Grünen" />
          <span class="gat-header__brand-text">
            <span class="gat-header__wordmark">Vorlagen</span>
            <span class="gat-header__subbrand">
              <span class="gat-header__subbrand-pill" aria-hidden="true">NÖ</span>
              Ein Projekt der Grünen Niederösterreich
            </span>
          </span>
        </a>
        <nav aria-label="Hauptnavigation">
          <ul class="gat-header__nav-list">
            <li><a href={url('/')}>Galerie</a></li>
            <li><a href={url('experiments/')}>Design-Experimente</a></li>
            <li><a href="https://grueneat.github.io/werkzeuge/">Werkzeuge</a></li>
          </ul>
        </nav>
        <a
          href="mailto:florian.motlik@gruene.at"
          class="gat-header__support"
          title="Bei Fragen oder Feedback an den Betreuer dieses Tools schreiben"
          aria-label="Support-E-Mail florian.motlik@gruene.at"
        >
          <svg
            class="gat-header__support-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" />
          </svg>
          <span class="gat-header__support-label">florian.motlik@gruene.at</span>
        </a>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>Grüne NÖ · Skelett-Vorlagen für lokale Gruppen</footer>
  </body>
</html>
