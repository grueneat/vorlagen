      "sla": "templates/flyer-a6-hochformat-gruenes-cover/fonts/montserrat/montserrat.sla"
    },
    {
      "slug": "montserrat-eng4",
      "name": "Montserrat eng (−4)",
      "license": "SIL OFL 1.1",
      "source": "https://github.com/google/fonts/tree/main/ofl/montserrat",
      "family": "Montserrat",
      "summary": "Montserrat mit ausgewogen verengtem Tracking (−4 %): gleiche, als beste empfundene Buchstabenform, aber spürbar kompaktere Buchstaben- und Wortabstände. Reaktion darauf, dass Montserrat von Haus aus breit läuft und es keinen offiziellen condensed Schnitt gibt. Wirkt natürlich, nichts drängt. Einsatz: Montserrat-Look ohne den lockeren Standard-Satz.",
