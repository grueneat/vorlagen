---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const templates = await getCollection('templates');

// Astro's import.meta.env.BASE_URL ends with a slash and equals the base
// config (currently '/vorlagen/'). Asset paths emitted by gallery_build.py
// start with '/templates/...' — strip the leading '/' so we don't get
// '//templates/...' when joining.
const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

// Group templates by category. Templates without a category land in
// `other:` so they remain visible until tagged.
type T = typeof templates[number];
const groups = new Map<string, { label: string; items: T[] }>();
for (const t of templates) {
  const id = t.data.category ?? 'other';
  const label = t.data.category_label ?? 'Sonstige';
  if (!groups.has(id)) groups.set(id, { label, items: [] });
  groups.get(id)!.items.push(t);
}

const PRIMARY_ORDER = ['flyer', 'falzflyer', 'plakat', 'postkarte', 'zeitung', 'tischschild', 'tueranhaenger'];
const orderedCategories = [
  ...PRIMARY_ORDER.filter(c => groups.has(c)),
  ...[...groups.keys()].filter(c => !PRIMARY_ORDER.includes(c)).sort(),
];

function pickPreview(items: T[]): string | null {
  for (const t of items) {
    const p = t.data._previews?.[0]?.src;
    if (p) return url(p);
  }
  return null;
}

for (const g of groups.values()) {
  g.items.sort((a, b) =>
    (a.data.variant_label ?? a.data.title).localeCompare(b.data.variant_label ?? b.data.title)
  );
}
---
<Base title="Vorlagen-Galerie">
  <h1>Vorlagen-Galerie</h1>
  <p>Skelett-Vorlagen für Falzflyer, Plakate, Postkarten, Zeitungen und mehr. Datei runterladen, in Scribus öffnen, eigene Inhalte einsetzen.</p>
  <a href={url('experiments/')} class="app-cta app-cta--first">
    <div>
      <strong class="app-cta__title">Design-Experimente</strong>
      <span class="app-cta__sub">Click-to-rank Voting auf Layout-Varianten — Hypothesen von mehreren LLMs.</span>
    </div>
    <span class="app-cta__action">Ansehen →</span>
  </a>

  <a href={url('schriften/')} class="app-cta">
    <div>
      <strong class="app-cta__title">Freie Schriften</strong>
      <span class="app-cta__sub">Vergleich freier Gotham-Alternativen am Flyer-Beispiel — fünf SIL-OFL-Schriften gegenübergestellt.</span>
    </div>
    <span class="app-cta__action">Ansehen →</span>
  </a>

  <h2 style="margin-top: 2.5rem;">Vorlagen-Typen</h2>
  <p style="color: var(--gat-web-text-mute); margin-top: -0.25rem;">{orderedCategories.length} Typen · {templates.length} Varianten</p>

  <div class="app-card-grid">
    {orderedCategories.map(cat => {
      const g = groups.get(cat)!;
      const cover = pickPreview(g.items);
      const n = g.items.length;
      return (
        <a
          href={url(`typ/${cat}/`)}
          class="app-card"
        >
          {cover && (
            <div class="app-card__media">
              <img src={cover} alt={g.label} loading="lazy" />
            </div>
          )}
          <div class="app-card__body">
            <h3>{g.label}</h3>
            <span class="app-card__meta">{n} {n === 1 ? 'Variante' : 'Varianten'}</span>
            <ul class="app-card__list">
              {g.items.slice(0, 3).map(t => (
                <li>{t.data.variant_label ?? t.data.title}</li>
              ))}
              {g.items.length > 3 && <li>… {g.items.length - 3} weitere</li>}
            </ul>
          </div>
        </a>
      );
    })}
  </div>
</Base>
