---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const templates = await getCollection('templates');
templates.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Astro's import.meta.env.BASE_URL ends with a slash and equals the base
// config (currently '/vorlagen/'). Asset paths emitted by gallery_build.py
// start with '/templates/...' — strip the leading '/' so we don't get
// '//templates/...' when joining.
const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');
---
<Base title="Vorlagen-Galerie">
  <h1>Vorlagen-Galerie</h1>
  <p>Skelett-Vorlagen für Postkarten, Plakate und Zeitungen. Datei runterladen, in Scribus öffnen, eigene Inhalte einsetzen.</p>
  <a
    href={url('experiments/')}
    style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; padding: 1rem 1.25rem; background: var(--gruen-dunkel); color: white; border-radius: 8px; text-decoration: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08);"
  >
    <div>
      <strong style="display: block; font-size: 1.05rem;">Design-Experimente</strong>
      <span style="font-size: 0.9em; opacity: 0.9;">Click-to-rank Voting auf Layout-Varianten — Hypothesen von mehreren LLMs.</span>
    </div>
    <span style="font-size: 0.9em; padding: 0.4rem 0.8rem; border: 1px solid rgba(255,255,255,0.5); border-radius: 4px; white-space: nowrap;">Ansehen →</span>
  </a>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
    {templates.map(t => (
      <a href={url(`templates/${t.id}/`)} style="text-decoration: none; color: inherit; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden; display: block; transition: transform 0.15s;">
        {t.data._previews && t.data._previews.length > 0 && (
          <div style="aspect-ratio: 3 / 4; background: #eee; display: flex; align-items: center; justify-content: center; overflow: hidden;">
            <img src={url(t.data._previews[0].src)} alt={t.data.title} loading="lazy" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
          </div>
        )}
        <div style="padding: 1rem;">
          <h3 style="margin: 0 0 0.5rem 0;">{t.data.title}</h3>
          {t.data.format && <span style="color: #666; font-size: 0.85em;">{t.data.format}{t.data.pages ? ` · ${t.data.pages} Seiten` : ''}</span>}
          {t.data.type === 'family' && <span style="color: #666; font-size: 0.85em;">Familie · {t.data.sizes?.length} Größen</span>}
          <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9em;">{t.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</Base>
