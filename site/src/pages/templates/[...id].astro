---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const templates = await getCollection('templates');
  return templates.map(t => ({ params: { id: t.id }, props: { t } }));
}
const { t } = Astro.props;
const { Content } = await render(t);

const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

// Breadcrumb category step. Mirrors the grouping in index.astro /
// typ/[category].astro: templates without a category fall back to `other`,
// for which typ/[category].astro still generates a route.
const catId = t.data.category ?? 'other';
const catLabel = t.data.category_label ?? 'Sonstige';
---
<Base title={t.data.title}>
  <Breadcrumb items={[
    { label: 'Galerie', href: url('/') },
    { label: catLabel, href: url(`typ/${catId}/`) },
    { label: t.data.title },
  ]} />
  <h1>{t.data.title}</h1>
  <p>{t.data.description}</p>

  {t.data._previews && t.data._previews.length > 0 && (
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; margin: 2rem 0;">
      {t.data._previews.map(p => {
        // Issue #28: every preview thumbnail clicks through to a hi-res
        // version rendered at 150 dpi (vs 50–100 dpi for thumbnails).
        // Hi-res lives next to the thumbnail with `-hires` suffix
        // (page-01.png → page-01-hires.png) and is mirrored to
        // site/public/templates/<id>/ by the render pipeline.
        const hiresSrc = p.src.replace(/\.png$/, '-hires.png');
        return (
          <a
            href={url(hiresSrc)}
            class="preview-link"
            data-hires={url(hiresSrc)}
            data-label={p.label}
            style="display: block; background: white; padding: 0.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); text-decoration: none; color: inherit; cursor: zoom-in;"
            aria-label={`Vergrößerte Vorschau öffnen: ${p.label}`}
          >
            <img src={url(p.src)} alt={p.label} loading="lazy" style="width: 100%; height: auto; display: block;" />
            <div style="text-align: center; font-size: 0.8em; margin-top: 0.5rem; color: #666;">{p.label}</div>
          </a>
        );
      })}
    </div>
  )}

  <!-- Lightbox overlay for hi-res previews (Issue #28). Plain HTML +
       inline JS — keeps the page a static Astro site with no framework.
       Navigates between previews via buttons, arrow keys and touch-swipe. -->
  <div id="preview-lightbox" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 1000; cursor: zoom-out; padding: 2rem; box-sizing: border-box; align-items: center; justify-content: center;">
    <button id="preview-close" type="button" aria-label="Schließen" style="position: absolute; top: 1rem; right: 1rem; background: white; color: black; border: none; border-radius: 4px; padding: 0.5rem 1rem; font-size: 1rem; cursor: pointer; z-index: 2;">Schließen ✕</button>
    <div id="preview-label" style="position: absolute; top: 1rem; left: 1rem; color: white; font-size: 0.95rem; z-index: 2;"></div>
    <button id="preview-prev" type="button" aria-label="Vorheriges Bild" style="display: none; position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); color: black; border: none; border-radius: 50%; width: 3rem; height: 3rem; font-size: 1.7rem; line-height: 1; cursor: pointer; z-index: 2;">‹</button>
    <button id="preview-next" type="button" aria-label="Nächstes Bild" style="display: none; position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); color: black; border: none; border-radius: 50%; width: 3rem; height: 3rem; font-size: 1.7rem; line-height: 1; cursor: pointer; z-index: 2;">›</button>
    <img id="preview-image" src="" alt="" style="max-width: calc(100vw - 7rem); max-height: calc(100vh - 4rem); display: block; object-fit: contain; cursor: zoom-out;" />
  </div>

  <script is:inline>
    (function () {
      const overlay = document.getElementById('preview-lightbox');
      const img = document.getElementById('preview-image');
      const label = document.getElementById('preview-label');
      const closeBtn = document.getElementById('preview-close');
      const prevBtn = document.getElementById('preview-prev');
      const nextBtn = document.getElementById('preview-next');
      const links = Array.prototype.slice.call(document.querySelectorAll('a.preview-link'));
      if (!overlay || !img || !label || !closeBtn || !prevBtn || !nextBtn || links.length === 0) return;

      let current = -1;
      const multiple = links.length > 1;
      prevBtn.style.display = multiple ? 'block' : 'none';
      nextBtn.style.display = multiple ? 'block' : 'none';

      function show(index) {
        current = (index + links.length) % links.length;
        const a = links[current];
        img.src = a.dataset.hires;
        img.alt = a.dataset.label || '';
        label.textContent = multiple
          ? (a.dataset.label || '') + ' — ' + (current + 1) + ' / ' + links.length
          : (a.dataset.label || '');
      }
      function open(index) {
        show(index);
        // Switch to flex so the image is centred on both axes.
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      function close() {
        overlay.style.display = 'none';
        img.src = '';
        document.body.style.overflow = '';
      }
      function step(delta) { show(current + delta); }

      links.forEach(function (a, i) {
        a.addEventListener('click', function (ev) { ev.preventDefault(); open(i); });
      });
      closeBtn.addEventListener('click', function (ev) { ev.stopPropagation(); close(); });
      prevBtn.addEventListener('click', function (ev) { ev.stopPropagation(); step(-1); });
      nextBtn.addEventListener('click', function (ev) { ev.stopPropagation(); step(1); });
      overlay.addEventListener('click', function (ev) {
        if (ev.target === overlay || ev.target === img) close();
      });
      document.addEventListener('keydown', function (ev) {
        if (overlay.style.display === 'none') return;
        if (ev.key === 'Escape') close();
        else if (multiple && ev.key === 'ArrowLeft') step(-1);
        else if (multiple && ev.key === 'ArrowRight') step(1);
      });

      // Touch swipe (mobile): a horizontal drag over 40px navigates.
      let startX = null, startY = null;
      overlay.addEventListener('touchstart', function (ev) {
        startX = ev.changedTouches[0].clientX;
        startY = ev.changedTouches[0].clientY;
      }, { passive: true });
      overlay.addEventListener('touchend', function (ev) {
        if (startX === null) return;
        const dx = ev.changedTouches[0].clientX - startX;
        const dy = ev.changedTouches[0].clientY - startY;
        if (multiple && Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          step(dx < 0 ? 1 : -1);
        }
        startX = startY = null;
      }, { passive: true });
    })();
  </script>

  <h2>Download</h2>
  <p>Bitte die Vorlage mit dem Impressum eures Bundeslandes herunterladen.</p>
  <ul>
    {t.data._downloads && t.data._downloads.map(d => (
      <li>
        {d.label}: <a href={url(d.sla)}>SLA herunterladen</a>
      </li>
    ))}
  </ul>
  {t.data._preview_pdf && (
    <p>Gemeinsame Vorschau: <a href={url(t.data._preview_pdf)}>Vorschau-PDF</a></p>
  )}

  <h2>Anleitung</h2>
  <Content />
</Base>
