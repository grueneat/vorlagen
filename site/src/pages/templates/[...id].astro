---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const templates = await getCollection('templates');
  return templates.map(t => ({ params: { id: t.id }, props: { t } }));
}
const { t } = Astro.props;
const { Content } = await render(t);

const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

// Breadcrumb category step. Mirrors the grouping in index.astro /
// typ/[category].astro: templates without a category fall back to `other`,
// for which typ/[category].astro still generates a route.
const catId = t.data.category ?? 'other';
const catLabel = t.data.category_label ?? 'Sonstige';
---
<Base title={t.data.title}>
  <Breadcrumb items={[
    { label: 'Galerie', href: url('/') },
    { label: catLabel, href: url(`typ/${catId}/`) },
    { label: t.data.title },
  ]} />
  <h1 class="gat-headline">{t.data.title}</h1>
  <p>{t.data.description}</p>

  {t.data._previews && t.data._previews.length > 0 && (
    <div class="app-preview-grid">
      {t.data._previews.map((p, i) => {
        // Issue #28: every preview thumbnail clicks through to a hi-res
        // version rendered at 150 dpi (vs 50–100 dpi for thumbnails).
        // Hi-res lives next to the thumbnail with `-hires` suffix
        // (page-01.png → page-01-hires.png) and is mirrored to
        // site/public/templates/<id>/ by the render pipeline.
        const hiresSrc = p.src.replace(/\.png$/, '-hires.png');
        return (
          <a
            href={url(hiresSrc)}
            class="app-lightbox-trigger app-preview-grid__item"
            data-lightbox-target="preview-lightbox"
            data-lightbox-group="default"
            data-lightbox-index={i}
            data-hires={url(hiresSrc)}
            data-label={p.label}
            aria-label={`Vergrößerte Vorschau öffnen: ${p.label}`}
          >
            <img src={url(p.src)} alt={p.label} loading="lazy" />
            <div class="app-preview-grid__caption">{p.label}</div>
          </a>
        );
      })}
    </div>
  )}

  {/* Shared lightbox component (Issue #126 Phase 2). Konsolidiert
      die lokal duplizierten Lightbox-Implementierungen
      (templates, experiments) auf <dialog class="gat-modal">. */}
  <Lightbox id="preview-lightbox" hasNav />

  <h2 class="gat-headline">Download</h2>
  <p>Bitte die Vorlage mit dem Impressum eures Bundeslandes herunterladen.</p>
  <ul>
    {t.data._downloads && t.data._downloads.map(d => (
      <li>
        {d.label}: <a href={url(d.sla)}>SLA herunterladen</a>
      </li>
    ))}
  </ul>
  {t.data._preview_pdf && (
    <p>Gemeinsame Vorschau: <a href={url(t.data._preview_pdf)}>Vorschau-PDF</a></p>
  )}

  <h2 class="gat-headline">Anleitung</h2>
  <Content />
</Base>
