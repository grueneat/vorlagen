---
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import data from '../../data/schriften.json';
import bewertung from '../../data/schriften-bewertung.json';

const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

// schriften.json (tools/fonts_compare_build.py): per-font metadata + one entry
// per flyer page with the per-font preview paths. schriften-bewertung.json:
// the hand-maintained decision matrix (never regenerated by the build tool).
const fonts = data.fonts;
const pages = data.pages;
// Loosely typed so the template (parsed as JSX, where `<>` would be read as
// tags) needs no inline TypeScript casts.
const krit = bewertung.kriterien as Array<{
  label: string;
  kind: string;
  hinweis?: string;
  werte: Record<string, any>;
}>;
const emp = bewertung.empfehlung;

// Column order for the matrix mirrors schriften.json (Original first).
const cols = fonts.map((f) => f.slug);
const shortName = (slug: string) =>
  slug === 'original' ? 'Gotham Narrow' : (fonts.find((f) => f.slug === slug)?.name ?? slug);

// Empfehlungs-Tag steuert die Farbakzente quer durch die Seite.
// Issue #126 Phase 2: Status-Lozenges nutzen .gat-tag --ok/--info/--error
// statt hartkodierter Hex-Werte. `accent` ist die Akzent-CSS-Variable für
// Border-Top/Border-Left/Ratingstift — wir greifen direkt auf die
// DS-Tag-Tokens zu.
const primary = emp.primaer.slug;
const secondary = emp.zweitwahl.slug;
const avoid = emp.abraten.map((a) => a.slug);
type Tag = { label: string; mod: 'ok' | 'info' | 'error'; accent: string } | null;
const tagFor = (slug: string): Tag => {
  if (slug === primary) return { label: 'Empfehlung', mod: 'ok', accent: 'var(--gat-web-tag-ok-text)' };
  if (slug === secondary) return { label: 'Zweitwahl', mod: 'info', accent: 'var(--gat-web-tag-info-text)' };
  if (avoid.includes(slug)) return { label: 'Nicht empfohlen', mod: 'error', accent: 'var(--gat-web-tag-error-text)' };
  return null;
};
const dotColor = (v: number) =>
  v >= 3 ? 'var(--gat-web-tag-ok-text)'
    : v === 2 ? 'var(--gat-color-hellgruen)'
    : v === 1 ? 'var(--gat-web-tag-warn-text)'
    : 'var(--gat-web-tag-error-text)';

// Live web-font specimens. The six SIL-OFL alternatives are self-hosted
// (site/public/fonts/) and embedded via @font-face. Tahoma is a proprietary
// system font — shown via the locally installed copy (present on Windows),
// never embedded. Gotham Narrow cannot be embedded at all; it is shown in the
// rendered-flyer comparison further down.
const specimens = [
  { slug: 'barlow-semi-condensed', name: 'Barlow Semi Condensed', dir: 'barlow-semi-condensed', base: 'BarlowSemiCondensed', web: true },
  { slug: 'saira-semi-condensed', name: 'Saira Semi Condensed', dir: 'saira-semi-condensed', base: 'SairaSemiCondensed', web: true },
  { slug: 'montserrat', name: 'Montserrat', dir: 'montserrat', base: 'Montserrat', web: true },
  { slug: 'outfit', name: 'Outfit', dir: 'outfit', base: 'Outfit', web: true },
  { slug: 'urbanist', name: 'Urbanist', dir: 'urbanist', base: 'Urbanist', web: true },
  { slug: 'raleway', name: 'Raleway', dir: 'raleway', base: 'Raleway', web: true },
  { slug: 'tahoma', name: 'Tahoma', dir: '', base: '', web: false },
];
const famOf = (s: { slug: string; web: boolean }) =>
  s.web ? `"Spec ${s.slug}", sans-serif` : 'Tahoma, "Segoe UI", Verdana, sans-serif';

// @font-face block — built here so the src URLs carry the deploy base path.
const fontFaceCss = specimens
  .filter((s) => s.web)
  .map((s) =>
    [
      ['Regular', 400],
      ['Bold', 700],
      ['Black', 900],
    ]
      .map(
        ([w, n]) =>
          `@font-face{font-family:"Spec ${s.slug}";` +
          `src:url("${url(`/fonts/${s.dir}/${s.base}-${w}.ttf`)}") format("truetype");` +
          `font-weight:${n};font-style:normal;font-display:swap;}`,
      )
      .join(''),
  )
  .join('');

// Brand palette (Base.astro :root) — shown as quick reference for the
// headline-on-colour samples.
const palette = [
  { name: 'Grün dunkel', hex: '#257639' },
  { name: 'Grün hell', hex: '#3e8a25' },
  { name: 'Gelb', hex: '#ffed00' },
  { name: 'Magenta', hex: '#e6007e' },
];
const HEADLINE = 'Mehr Grün für Niederösterreich.';
const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnop 0123456789 ßäöü €';
const KLEINTEXT =
  'Schrift, Farben und Logo sind verbindlich. Die Vorlagen werden zentral ' +
  'gepflegt und stehen allen Gliederungen zur Verfügung — Impressum, ' +
  'V.i.S.d.P. und Kontaktdaten je Anlass anpassen.';
---
<Base title="Schriften-Entscheidung">
  <style is:inline set:html={fontFaceCss}></style>

  <p><a href={url('/')}>← Zurück zur Galerie</a></p>
  <h1 class="gat-headline">Schriften-Vergleich — Entscheidungsgrundlage</h1>
  <p>
    Die Vorlagen sind in <strong>Gotham Narrow</strong> gesetzt — einer
    kommerziell lizenzierten Schrift, die <strong>nicht</strong> mit den
    Vorlagen an Gliederungen und Druckereien weitergegeben werden darf und
    laufende Kosten verursacht. Sie muss ersetzt werden. Diese Seite stellt
    die Kandidat:innen gegenüber: sechs frei (auch kommerziell) nutzbare,
    SIL-OFL-lizenzierte Alternativen — und, als bewusstes Negativbeispiel,
    <strong>Tahoma</strong>: die naheliegende „hat doch jeder"-Wahl, die
    gestalterisch jedoch nicht trägt.
  </p>
  <p style="color: var(--muted); font-size: 0.92em;">
    Verglichen wird auf drei Ebenen: am <strong>Schriftbild</strong> (eigene
    Muster, Headlines, Markenfarben), an den <strong>Eigenschaften</strong>
    (Bewertungstabelle) und am <strong>echten Flyer</strong>
    („Flyer A6 Hochformat – Grünes Cover", jede Seite in jeder Schrift
    gerendert). Ziel: schnell zu einer fundierten Entscheidung kommen.
  </p>

  {!data.rendered && (
    <div class="gat-callout gat-callout--warn">
      <p style="margin: 0; font-size: 0.9em;">
        Hinweis: Die Flyer-Renderings wurden in dieser Umgebung noch nicht
        erzeugt. Schriftmuster und Bewertung sind unabhängig davon nutzbar.
      </p>
    </div>
  )}

  <!-- ============ 1. Empfehlung auf einen Blick ============ -->
  <h2 class="gat-headline">Empfehlung auf einen Blick</h2>
  <div class="app-empfehlung-stack">
    <div class="gat-callout gat-callout--success">
      <div class="app-empfehlung__kicker">Empfehlung</div>
      <div class="app-empfehlung__name">{emp.primaer.name}</div>
      <p style="margin: 0; font-size: 0.94em;">{emp.primaer.text}</p>
    </div>
    <div class="gat-callout gat-callout--info">
      <div class="app-empfehlung__kicker">Zweitwahl</div>
      <div class="app-empfehlung__name">{emp.zweitwahl.name}</div>
      <p style="margin: 0; font-size: 0.94em;">{emp.zweitwahl.text}</p>
    </div>
    <div class="gat-callout gat-callout--danger">
      <div class="app-empfehlung__kicker">Davon abraten</div>
      {emp.abraten.map((a) => (
        <p style="margin: 0.4rem 0 0 0; font-size: 0.94em;">
          <strong>{a.name}:</strong> {a.text}
        </p>
      ))}
    </div>
  </div>

  <!-- ============ 2. Bewertungstabelle ============ -->
  <h2 class="gat-headline">Bewertung im Detail</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Bewertung: ●●● sehr gut · ●●○ gut · ●○○ schwach · ○○○ ungenügend.
    Tabelle ggf. seitlich scrollen.
  </p>
  {/*
    DS v2.2: .gat-table mit --sticky-col + --compact + --zebra im
    .gat-table-scroll-Wrapper. Erste Spalte (Kriterien) bleibt beim
    Quer-Scroll sichtbar. Der DS-Selektor `--sticky-col` deckt nur
    tbody-td:first-child / thead-th:first-child; Row-Header (<th>)
    braucht eine kleine seitenlokale Ergaenzung
    (.app-eval-rowhead-sticky in app.css), damit die scope="row"-
    Semantik erhalten bleibt. Numerische Spalten gibt es hier nicht
    (Ratings sind Glyph-Symbole, Ja/Nein sind Tags), daher kein __num.
  */}
  <div class="gat-table-scroll">
    <table class="gat-table gat-table--sticky-col gat-table--compact gat-table--zebra app-eval-rowhead-sticky">
      <thead>
        <tr>
          <th>Kriterium</th>
          {cols.map((slug) => {
            const t = tagFor(slug);
            const mod = t?.mod === 'error' ? 'error' : t?.mod;
            return (
              <th style={t ? `background: color-mix(in srgb, var(--gat-web-tag-${mod}-bg) 65%, white);` : ''}>
                <div style={`font-weight: bold; color: ${t ? t.accent : 'var(--gat-web-text)'};`}>{shortName(slug)}</div>
                {t && <span class={`gat-tag gat-tag--${t.mod} app-eval-col-tag`}>{t.label}</span>}
              </th>
            );
          })}
        </tr>
      </thead>
      <tbody>
        {krit.map((k) => (
          <tr>
            <th scope="row">
              {k.label}
              {k.hinweis && <div class="app-eval-rowhead-hint">{k.hinweis}</div>}
            </th>
            {cols.map((slug) => {
              const v = k.werte[slug];
              const t = tagFor(slug);
              const mod = t?.mod === 'error' ? 'error' : t?.mod;
              const isGesamt = k.label === 'Gesamturteil';
              const cellStyle = [
                k.kind !== 'text' ? 'text-align: center;' : '',
                t && isGesamt ? `background: color-mix(in srgb, var(--gat-web-tag-${mod}-bg) 65%, white);` : '',
              ].filter(Boolean).join(' ');
              return (
                <td style={cellStyle}>
                  {k.kind === 'rating' && (
                    <span class="app-eval-rating" title={`${v} von 3`}>
                      {[1, 2, 3].map((i) => (
                        <span class="app-eval-rating__dot" style={`background: ${i <= v ? dotColor(v) : 'var(--gat-web-hairline)'};`}></span>
                      ))}
                    </span>
                  )}
                  {k.kind === 'janein' && (
                    v
                      ? <span class="gat-tag gat-tag--ok">✓ Ja</span>
                      : <span class="gat-tag gat-tag--error">✗ Nein</span>
                  )}
                  {k.kind === 'text' && <span>{v}</span>}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- ============ 3. Schriftmuster im Direktvergleich ============ -->
  <h2 class="gat-headline">Schriftmuster im Direktvergleich</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Dieselbe Headline, Schnitt-Leiter und dasselbe Alphabet in jeder
    Schrift — isoliert vom Layout, damit sich die Buchstabenformen direkt
    vergleichen lassen.
  </p>
  <div class="app-specimen-grid">
    {specimens.map((s) => {
      const t = tagFor(s.slug);
      const fam = famOf(s);
      return (
        <div class="app-specimen" style={t ? `border-top: 4px solid ${t.accent};` : ''}>
          <div class="app-specimen__head">
            <h3 class="gat-headline" style="margin: 0;">{s.name}</h3>
            {t && <span class={`gat-tag gat-tag--${t.mod}`}>{t.label}</span>}
          </div>
          <div class="app-specimen__headline" style={`font-family: ${fam};`}>
            {HEADLINE}
          </div>
          <div class="app-specimen__weights">
            <div style={`font-family: ${fam}; font-weight: 400;`}>Regular — Fließtext</div>
            <div style={`font-family: ${fam}; font-weight: 700;`}>Bold — Auszeichnung</div>
            <div style={`font-family: ${fam}; font-weight: 900;`}>
              {s.web ? 'Black — Headline' : 'Bold — kein schwererer Schnitt'}
            </div>
          </div>
          <div class="app-specimen__glyphs" style={`font-family: ${fam};`}>
            {GLYPHS}
          </div>
          <div class="app-specimen__copy" style={`font-family: ${fam};`}>
            {KLEINTEXT}
          </div>
          {!s.web && (
            <p class="app-specimen__warning">
              Tahoma ist proprietär und wird hier aus der lokal installierten
              Systemschrift angezeigt (auf Windows vorhanden) — sonst eine
              Ersatzschrift. Tahoma hat nur zwei Schnitte: für Headlines fehlt
              ein schwererer Black-/Ultra-Schnitt.
            </p>
          )}
        </div>
      );
    })}
  </div>
  <p style="color: var(--muted); font-size: 0.88em; margin-top: -1rem;">
    Gotham Narrow ist proprietär und lässt sich nicht als Web-Schrift
    einbetten — das Original-Schriftbild ist im Flyer-Vergleich ganz unten
    in der ersten Spalte zu sehen.
  </p>

  <!-- ============ 4. Headline & Markenfarben ============ -->
  <h2 class="gat-headline">Headline auf Markenfarbe</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Die Headline-Behandlung des Flyer-Covers (weiß auf Grün, ein Akzentwort
    in Gelb) — je Schrift isoliert, plus die verbindliche Markenpalette.
  </p>
  <div class="app-palette">
    {palette.map((c) => (
      <div class="app-palette__chip">
        <span class="app-palette__swatch" style={`background: ${c.hex};`}></span>
        <span><strong>{c.name}</strong><br /><span style="color: var(--muted);">{c.hex}</span></span>
      </div>
    ))}
  </div>
  <div class="app-cover-grid">
    {specimens.map((s) => {
      const fam = famOf(s);
      return (
        <div class="app-cover">
          <div class="app-cover__hero">
            <div class="app-cover__title" style={`font-family: ${fam};`}>
              Mehr <span style="color: var(--gelb);">Grün</span> wählen.
            </div>
          </div>
          <div class="app-cover__caption">
            <span style="font-weight: bold;">{s.name}</span>
            {!s.web && <span style="color: var(--gat-web-tag-error-text);">Systemschrift</span>}
          </div>
        </div>
      );
    })}
  </div>

  <!-- ============ 5. Schriften am Flyer — Karten ============ -->
  <h2 class="gat-headline">Schriften im Überblick</h2>
  <div class="app-font-grid">
    {fonts.map((f) => {
      const t = tagFor(f.slug);
      const proprietary = f.original || f.license.startsWith('Propriet');
      return (
        <div class="app-font-card" style={t ? `border-left: 4px solid ${t.accent};` : ''}>
          <div class="app-font-card__head">
            <h3 class="gat-headline" style="margin: 0 0 0.25rem 0;">{f.name}</h3>
            {t && <span class={`gat-tag gat-tag--${t.mod}`}>{t.label}</span>}
          </div>
          <div class="app-font-card__meta">
            {proprietary
              ? <span><strong style="color: var(--gat-web-tag-error-text);">Proprietär</strong> · {f.license} · <a href={f.source}>Schrift-Info</a></span>
              : <span>{f.license} · <a href={f.source}>Quelle</a></span>}
          </div>
          <p class="app-font-card__summary">{f.summary}</p>
          <div class="app-font-card__action">
            {f.pdf
              ? <a href={url(f.pdf)}>{f.original ? 'Original-Flyer als PDF' : `Flyer als PDF (${f.name})`}</a>
              : f.slug === 'tahoma'
                ? <span style="color: var(--gat-web-text-soft);">Kein PDF — proprietäre Schrift wird nicht mitveröffentlicht</span>
                : <a href={url(f.sla)}>Variant-SLA herunterladen</a>}
          </div>
        </div>
      );
    })}
  </div>

  <!-- ============ 6. Seitenvergleich am Flyer ============ -->
  <h2 class="gat-headline">Seitenvergleich am echten Flyer</h2>
  <p style="color: var(--gat-web-text-mute); margin-top: -0.25rem;">
    {pages.length} Flyer-Seiten · je {fonts.length} Spalten (Original +
    {fonts.length - 1} Schriften). Ein Klick öffnet die Großansicht mit
    Umschalter zwischen den Schrift-Versionen.
  </p>

  <div class="app-page-stack">
    {pages.map(pg => (
      <section>
        <h3 class="gat-headline" style="margin: 0 0 0.75rem 0;">Seite {pg.page}</h3>
        <div class="app-page-cols" style={`grid-template-columns: repeat(${fonts.length}, 1fr);`}>
          {fonts.map((f, fi) => {
            const cell = pg.fonts[f.slug] || { thumb: null, hires: null };
            // " · " separates the font name from the page so the lightbox can
            // recover the (possibly dash-containing) font name reliably.
            const label = `${f.name} · Seite ${pg.page}`;
            return (
              <div class={`app-page-cell${f.original ? ' app-page-cell--original' : ''}`}>
                {cell.thumb ? (
                  <a
                    href={url(cell.hires || cell.thumb)}
                    class="app-schrift-preview"
                    data-lightbox-target="schrift-lightbox"
                    data-lightbox-group={`page-${pg.page}`}
                    data-lightbox-index={fi}
                    data-hires={url(cell.hires || cell.thumb)}
                    data-label={label}
                    data-font-name={f.name}
                    aria-label={`Vergrößern: ${label}`}
                  >
                    <img src={url(cell.thumb)} alt={label} loading="lazy" />
                  </a>
                ) : (
                  <div class="app-page-cell__empty">Noch nicht gerendert</div>
                )}
                <div class={`app-page-cell__caption${f.original ? ' app-page-cell__caption--original' : ''}`}>{f.name}</div>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  {/* Shared lightbox component (Issue #126 Phase 2). Konsolidiert mit
      templates + experiments auf <dialog class="gat-modal">. Der
      Schriften-Switcher unten in `__extras` wird per
      `lightbox:render`-Event aus der Gruppe abgeleitet. */}
  <Lightbox id="schrift-lightbox" hasNav hasExtras />

  <script is:inline>
    (function () {
      // Schriften-spezifischer Layer: synchronisiert die Font-Switch-Leiste
      // mit der aktuellen Lightbox-Position. Die Lightbox selbst
      // (Backdrop/Esc/Pfeile/Swipe) kommt aus components/Lightbox.astro.
      var dialog = document.getElementById('schrift-lightbox');
      if (!dialog) return;
      var extras = dialog.querySelector('[data-lightbox-extras]');
      if (!extras) return;

      function fontName(a) {
        return a.getAttribute('data-font-name') ||
               ((a.getAttribute('data-label') || '').split(' · ')[0]);
      }

      function rebuildBar(detail) {
        var group = detail.group || [];
        var index = detail.index;
        extras.textContent = '';
        group.forEach(function (g, i) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = fontName(g);
          btn.className = i === index ? 'app-schrift-tab app-schrift-tab--active'
                                       : 'app-schrift-tab';
          btn.addEventListener('click', function (ev) {
            ev.stopPropagation();
            if (dialog.__lightbox) dialog.__lightbox.setIndex(i);
          });
          extras.appendChild(btn);
        });
      }

      dialog.addEventListener('lightbox:render', function (ev) {
        rebuildBar(ev.detail || {});
      });
      dialog.addEventListener('lightbox:open', function (ev) {
        rebuildBar(ev.detail || {});
      });
    })();
  </script>
</Base>
