---
import Base from '../../layouts/Base.astro';
import data from '../../data/schriften.json';
import bewertung from '../../data/schriften-bewertung.json';

const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

// schriften.json (tools/fonts_compare_build.py): per-font metadata + one entry
// per flyer page with the per-font preview paths. schriften-bewertung.json:
// the hand-maintained decision matrix (never regenerated by the build tool).
const fonts = data.fonts;
const pages = data.pages;
// Loosely typed so the template (parsed as JSX, where `<>` would be read as
// tags) needs no inline TypeScript casts.
const krit = bewertung.kriterien as Array<{
  label: string;
  kind: string;
  hinweis?: string;
  werte: Record<string, any>;
}>;
const emp = bewertung.empfehlung;

// Column order for the matrix mirrors schriften.json (Original first).
const cols = fonts.map((f) => f.slug);
const shortName = (slug: string) =>
  slug === 'original' ? 'Gotham Narrow' : (fonts.find((f) => f.slug === slug)?.name ?? slug);

// Recommendation tags drive the colour accents across the page.
const primary = emp.primaer.slug;
const secondary = emp.zweitwahl.slug;
const avoid = emp.abraten.map((a) => a.slug);
type Tag = { label: string; fg: string; bg: string } | null;
const tagFor = (slug: string): Tag => {
  if (slug === primary) return { label: 'Empfehlung', fg: '#0f5c2e', bg: '#e3f5e8' };
  if (slug === secondary) return { label: 'Zweitwahl', fg: '#257639', bg: '#eaf3ee' };
  if (avoid.includes(slug)) return { label: 'Nicht empfohlen', fg: '#b3261e', bg: '#fbe9e7' };
  return null;
};
const dotColor = (v: number) =>
  v >= 3 ? '#0f5c2e' : v === 2 ? '#3e8a25' : v === 1 ? '#e69500' : '#b3261e';

// Live web-font specimens. The five SIL-OFL alternatives are self-hosted
// (site/public/fonts/) and embedded via @font-face. Tahoma is a proprietary
// system font — shown via the locally installed copy (present on Windows),
// never embedded. Gotham Narrow cannot be embedded at all; it is shown in the
// rendered-flyer comparison further down.
const specimens = [
  { slug: 'barlow-semi-condensed', name: 'Barlow Semi Condensed', dir: 'barlow-semi-condensed', base: 'BarlowSemiCondensed', web: true },
  { slug: 'montserrat', name: 'Montserrat', dir: 'montserrat', base: 'Montserrat', web: true },
  { slug: 'outfit', name: 'Outfit', dir: 'outfit', base: 'Outfit', web: true },
  { slug: 'urbanist', name: 'Urbanist', dir: 'urbanist', base: 'Urbanist', web: true },
  { slug: 'raleway', name: 'Raleway', dir: 'raleway', base: 'Raleway', web: true },
  { slug: 'tahoma', name: 'Tahoma', dir: '', base: '', web: false },
];
const famOf = (s: { slug: string; web: boolean }) =>
  s.web ? `"Spec ${s.slug}", sans-serif` : 'Tahoma, "Segoe UI", Verdana, sans-serif';

// @font-face block — built here so the src URLs carry the deploy base path.
const fontFaceCss = specimens
  .filter((s) => s.web)
  .map((s) =>
    [
      ['Regular', 400],
      ['Bold', 700],
      ['Black', 900],
    ]
      .map(
        ([w, n]) =>
          `@font-face{font-family:"Spec ${s.slug}";` +
          `src:url("${url(`/fonts/${s.dir}/${s.base}-${w}.ttf`)}") format("truetype");` +
          `font-weight:${n};font-style:normal;font-display:swap;}`,
      )
      .join(''),
  )
  .join('');

// Brand palette (Base.astro :root) — shown as quick reference for the
// headline-on-colour samples.
const palette = [
  { name: 'Grün dunkel', hex: '#257639' },
  { name: 'Grün hell', hex: '#3e8a25' },
  { name: 'Gelb', hex: '#ffed00' },
  { name: 'Magenta', hex: '#e6007e' },
];
const HEADLINE = 'Mehr Grün für Niederösterreich.';
const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnop 0123456789 ßäöü €';
const KLEINTEXT =
  'Schrift, Farben und Logo sind verbindlich. Die Vorlagen werden zentral ' +
  'gepflegt und stehen allen Gliederungen zur Verfügung — Impressum, ' +
  'V.i.S.d.P. und Kontaktdaten je Anlass anpassen.';
---
<Base title="Schriften-Entscheidung">
  <style is:inline set:html={fontFaceCss}></style>

  <p><a href={url('/')}>← Zurück zur Galerie</a></p>
  <h1>Schriften-Vergleich — Entscheidungsgrundlage</h1>
  <p>
    Die Vorlagen sind in <strong>Gotham Narrow</strong> gesetzt — einer
    kommerziell lizenzierten Schrift, die <strong>nicht</strong> mit den
    Vorlagen an Gliederungen und Druckereien weitergegeben werden darf und
    laufende Kosten verursacht. Sie muss ersetzt werden. Diese Seite stellt
    die Kandidat:innen gegenüber: fünf frei (auch kommerziell) nutzbare,
    SIL-OFL-lizenzierte Alternativen — und, als bewusstes Negativbeispiel,
    <strong>Tahoma</strong>: die naheliegende „hat doch jeder"-Wahl, die
    gestalterisch jedoch nicht trägt.
  </p>
  <p style="color: var(--muted); font-size: 0.92em;">
    Verglichen wird auf drei Ebenen: am <strong>Schriftbild</strong> (eigene
    Muster, Headlines, Markenfarben), an den <strong>Eigenschaften</strong>
    (Bewertungstabelle) und am <strong>echten Flyer</strong>
    („Flyer A6 Hochformat – Grünes Cover", jede Seite in jeder Schrift
    gerendert). Ziel: schnell zu einer fundierten Entscheidung kommen.
  </p>

  {!data.rendered && (
    <p style="background: var(--gelb); color: #222; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.9em;">
      Hinweis: Die Flyer-Renderings wurden in dieser Umgebung noch nicht
      erzeugt. Schriftmuster und Bewertung sind unabhängig davon nutzbar.
    </p>
  )}

  <!-- ============ 1. Empfehlung auf einen Blick ============ -->
  <h2>Empfehlung auf einen Blick</h2>
  <div style="display: grid; gap: 1rem; margin: 1rem 0 2rem 0;">
    <div style="background: #e3f5e8; border-left: 6px solid #0f5c2e; border-radius: 8px; padding: 1.1rem 1.25rem;">
      <div style="font-size: 0.78em; font-weight: bold; letter-spacing: 0.06em; text-transform: uppercase; color: #0f5c2e;">Empfehlung</div>
      <div style="font-size: 1.25rem; font-weight: bold; color: #0f5c2e; margin: 0.15rem 0 0.35rem 0;">{emp.primaer.name}</div>
      <p style="margin: 0; color: #1d3b2a; font-size: 0.94em;">{emp.primaer.text}</p>
    </div>
    <div style="background: #eaf3ee; border-left: 6px solid #257639; border-radius: 8px; padding: 1.1rem 1.25rem;">
      <div style="font-size: 0.78em; font-weight: bold; letter-spacing: 0.06em; text-transform: uppercase; color: #257639;">Zweitwahl</div>
      <div style="font-size: 1.15rem; font-weight: bold; color: #257639; margin: 0.15rem 0 0.35rem 0;">{emp.zweitwahl.name}</div>
      <p style="margin: 0; color: #2c3b33; font-size: 0.94em;">{emp.zweitwahl.text}</p>
    </div>
    <div style="background: #fbe9e7; border-left: 6px solid #b3261e; border-radius: 8px; padding: 1.1rem 1.25rem;">
      <div style="font-size: 0.78em; font-weight: bold; letter-spacing: 0.06em; text-transform: uppercase; color: #b3261e;">Davon abraten</div>
      {emp.abraten.map((a) => (
        <p style="margin: 0.4rem 0 0 0; color: #5a201b; font-size: 0.94em;">
          <strong>{a.name}:</strong> {a.text}
        </p>
      ))}
    </div>
  </div>

  <!-- ============ 2. Bewertungstabelle ============ -->
  <h2>Bewertung im Detail</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Bewertung: ●●● sehr gut · ●●○ gut · ●○○ schwach · ○○○ ungenügend.
    Tabelle ggf. seitlich scrollen.
  </p>
  <div style="overflow-x: auto; margin: 1rem 0 2.5rem 0;">
    <table style="border-collapse: collapse; width: 100%; min-width: 760px; font-size: 0.86em;">
      <thead>
        <tr>
          <th style="text-align: left; padding: 0.5rem 0.6rem; border-bottom: 2px solid #ccc; position: sticky; left: 0; background: var(--bg); z-index: 1;">Kriterium</th>
          {cols.map((slug) => {
            const t = tagFor(slug);
            return (
              <th style={`padding: 0.5rem 0.6rem; border-bottom: 2px solid #ccc; vertical-align: bottom; min-width: 92px;${t ? ` background: ${t.bg};` : ''}`}>
                <div style={`font-weight: bold; color: ${t ? t.fg : '#222'};`}>{shortName(slug)}</div>
                {t && <div style={`font-size: 0.82em; color: ${t.fg};`}>{t.label}</div>}
              </th>
            );
          })}
        </tr>
      </thead>
      <tbody>
        {krit.map((k, ri) => (
          <tr style={ri % 2 ? 'background: #f4f4f2;' : ''}>
            <th style={`text-align: left; font-weight: 600; padding: 0.5rem 0.6rem; vertical-align: top; position: sticky; left: 0; background: ${ri % 2 ? '#f4f4f2' : 'var(--bg)'}; z-index: 1;`}>
              {k.label}
              {k.hinweis && <div style="font-weight: 400; color: var(--muted); font-size: 0.86em;">{k.hinweis}</div>}
            </th>
            {cols.map((slug) => {
              const v = k.werte[slug];
              const t = tagFor(slug);
              return (
                <td style={`padding: 0.5rem 0.6rem; vertical-align: top; text-align: ${k.kind === 'text' ? 'left' : 'center'};${t && k.label === 'Gesamturteil' ? ` background: ${t.bg};` : ''}`}>
                  {k.kind === 'rating' && (
                    <span title={`${v} von 3`} style="white-space: nowrap;">
                      {[1, 2, 3].map((i) => (
                        <span style={`display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin: 0 1px; background: ${i <= v ? dotColor(v) : '#dcdcdc'};`}></span>
                      ))}
                    </span>
                  )}
                  {k.kind === 'janein' && (
                    v
                      ? <span style="color: #0f5c2e; font-weight: bold;">✓ Ja</span>
                      : <span style="color: #b3261e; font-weight: bold;">✗ Nein</span>
                  )}
                  {k.kind === 'text' && <span>{v}</span>}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- ============ 3. Schriftmuster im Direktvergleich ============ -->
  <h2>Schriftmuster im Direktvergleich</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Dieselbe Headline, Schnitt-Leiter und dasselbe Alphabet in jeder
    Schrift — isoliert vom Layout, damit sich die Buchstabenformen direkt
    vergleichen lassen.
  </p>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 1.25rem; margin: 1.25rem 0 2.5rem 0;">
    {specimens.map((s) => {
      const t = tagFor(s.slug);
      const fam = famOf(s);
      return (
        <div style={`background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 1.1rem 1.25rem;${t ? ` border-top: 4px solid ${t.fg};` : ''}`}>
          <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem;">
            <h3 style="margin: 0;">{s.name}</h3>
            {t && <span style={`font-size: 0.72em; font-weight: bold; text-transform: uppercase; letter-spacing: 0.04em; color: ${t.fg}; background: ${t.bg}; padding: 0.15rem 0.45rem; border-radius: 4px;`}>{t.label}</span>}
          </div>
          <div style={`font-family: ${fam}; font-weight: 900; font-size: 1.6rem; line-height: 1.15; color: var(--gruen-dunkel); margin: 0.6rem 0 0.7rem 0;`}>
            {HEADLINE}
          </div>
          <div style="border-top: 1px solid #eee; padding-top: 0.5rem;">
            <div style={`font-family: ${fam}; font-weight: 400; font-size: 1.05rem;`}>Regular — Fließtext</div>
            <div style={`font-family: ${fam}; font-weight: 700; font-size: 1.05rem;`}>Bold — Auszeichnung</div>
            <div style={`font-family: ${fam}; font-weight: 900; font-size: 1.05rem;`}>
              {s.web ? 'Black — Headline' : 'Bold — kein schwererer Schnitt'}
            </div>
          </div>
          <div style={`font-family: ${fam}; font-weight: 400; font-size: 0.82rem; color: #444; word-break: break-word; margin-top: 0.6rem;`}>
            {GLYPHS}
          </div>
          <div style={`font-family: ${fam}; font-weight: 400; font-size: 0.7rem; line-height: 1.45; color: #555; margin-top: 0.5rem;`}>
            {KLEINTEXT}
          </div>
          {!s.web && (
            <p style="margin: 0.7rem 0 0 0; font-size: 0.78em; color: #b3261e;">
              Tahoma ist proprietär und wird hier aus der lokal installierten
              Systemschrift angezeigt (auf Windows vorhanden) — sonst eine
              Ersatzschrift. Tahoma hat nur zwei Schnitte: für Headlines fehlt
              ein schwererer Black-/Ultra-Schnitt.
            </p>
          )}
        </div>
      );
    })}
  </div>
  <p style="color: var(--muted); font-size: 0.88em; margin-top: -1rem;">
    Gotham Narrow ist proprietär und lässt sich nicht als Web-Schrift
    einbetten — das Original-Schriftbild ist im Flyer-Vergleich ganz unten
    in der ersten Spalte zu sehen.
  </p>

  <!-- ============ 4. Headline & Markenfarben ============ -->
  <h2>Headline auf Markenfarbe</h2>
  <p style="color: var(--muted); margin-top: -0.25rem; font-size: 0.92em;">
    Die Headline-Behandlung des Flyer-Covers (weiß auf Grün, ein Akzentwort
    in Gelb) — je Schrift isoliert, plus die verbindliche Markenpalette.
  </p>
  <div style="display: flex; gap: 0.6rem; flex-wrap: wrap; margin: 1rem 0 1.25rem 0;">
    {palette.map((c) => (
      <div style="display: flex; align-items: center; gap: 0.45rem; font-size: 0.82em;">
        <span style={`width: 26px; height: 26px; border-radius: 4px; background: ${c.hex}; border: 1px solid rgba(0,0,0,0.15);`}></span>
        <span><strong>{c.name}</strong><br /><span style="color: var(--muted);">{c.hex}</span></span>
      </div>
    ))}
  </div>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-bottom: 2.5rem;">
    {specimens.map((s) => {
      const fam = famOf(s);
      return (
        <div style="border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <div style="background: var(--gruen-dunkel); padding: 1.4rem 1.25rem;">
            <div style={`font-family: ${fam}; font-weight: 900; font-size: 1.5rem; line-height: 1.1; color: white;`}>
              Mehr <span style="color: var(--gelb);">Grün</span> wählen.
            </div>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0.75rem; background: white; font-size: 0.82em;">
            <span style="font-weight: bold;">{s.name}</span>
            {!s.web && <span style="color: #b3261e;">Systemschrift</span>}
          </div>
        </div>
      );
    })}
  </div>

  <!-- ============ 5. Schriften am Flyer — Karten ============ -->
  <h2>Schriften im Überblick</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; margin: 1.25rem 0 2.5rem 0;">
    {fonts.map((f) => {
      const t = tagFor(f.slug);
      const proprietary = f.original || f.license.startsWith('Propriet');
      return (
        <div style={`background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 1.25rem;${t ? ` border-left: 4px solid ${t.fg};` : ''}`}>
          <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem;">
            <h3 style="margin: 0 0 0.25rem 0;">{f.name}</h3>
            {t && <span style={`font-size: 0.72em; font-weight: bold; text-transform: uppercase; color: ${t.fg}; background: ${t.bg}; padding: 0.15rem 0.45rem; border-radius: 4px;`}>{t.label}</span>}
          </div>
          <div style="color: #666; font-size: 0.85em; margin-bottom: 0.6rem;">
            {proprietary
              ? <span><strong style="color: #b3261e;">Proprietär</strong> · {f.license} · <a href={f.source}>Schrift-Info</a></span>
              : <span>{f.license} · <a href={f.source}>Quelle</a></span>}
          </div>
          <p style="margin: 0 0 0.75rem 0; color: #444; font-size: 0.9em;">{f.summary}</p>
          <div style="font-size: 0.85em;">
            {f.pdf
              ? <a href={url(f.pdf)}>{f.original ? 'Original-Flyer als PDF' : `Flyer als PDF (${f.name})`}</a>
              : f.slug === 'tahoma'
                ? <span style="color: #999;">Kein PDF — proprietäre Schrift wird nicht mitveröffentlicht</span>
                : <a href={url(f.sla)}>Variant-SLA herunterladen</a>}
          </div>
        </div>
      );
    })}
  </div>

  <!-- ============ 6. Seitenvergleich am Flyer ============ -->
  <h2>Seitenvergleich am echten Flyer</h2>
  <p style="color: #666; margin-top: -0.25rem;">
    {pages.length} Flyer-Seiten · je {fonts.length} Spalten (Original +
    {fonts.length - 1} Schriften). Ein Klick öffnet die Großansicht mit
    Umschalter zwischen den Schrift-Versionen.
  </p>

  <div style="display: flex; flex-direction: column; gap: 2rem; margin-top: 1.5rem;">
    {pages.map(pg => (
      <section>
        <h3 style="margin: 0 0 0.75rem 0;">Seite {pg.page}</h3>
        <div style={`display: grid; grid-template-columns: repeat(${fonts.length}, 1fr); gap: 1rem;`}>
          {fonts.map((f, fi) => {
            const cell = pg.fonts[f.slug] || { thumb: null, hires: null };
            // " · " separates the font name from the page so the lightbox can
            // recover the (possibly dash-containing) font name reliably.
            const label = `${f.name} · Seite ${pg.page}`;
            return (
              <div style={`background: white; padding: 0.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1);${f.original ? ' outline: 2px solid #3e8a25;' : ''}`}>
                {cell.thumb ? (
                  <a
                    href={url(cell.hires || cell.thumb)}
                    class="schrift-preview"
                    data-page={pg.page}
                    data-font-index={fi}
                    data-hires={url(cell.hires || cell.thumb)}
                    data-label={label}
                    style="display: block; text-decoration: none; color: inherit; cursor: zoom-in;"
                    aria-label={`Vergrößern: ${label}`}
                  >
                    <img src={url(cell.thumb)} alt={label} loading="lazy" style="width: 100%; height: auto; display: block;" />
                  </a>
                ) : (
                  <div style="aspect-ratio: 3 / 4; display: flex; align-items: center; justify-content: center; background: #f0f0f0; color: #999; font-size: 0.8em; text-align: center; padding: 0.5rem;">
                    Noch nicht gerendert
                  </div>
                )}
                <div style={`text-align: center; font-size: 0.78em; margin-top: 0.4rem; color: ${f.original ? '#222' : '#666'};${f.original ? ' font-weight: bold;' : ''}`}>{f.name}</div>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <!-- Lightbox: switches between the font versions of ONE flyer page.
       Plain HTML + inline JS (same pattern as templates/[...id].astro). -->
  <div id="schrift-lightbox" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 1000; padding: 2rem; box-sizing: border-box; align-items: center; justify-content: center;">
    <button id="schrift-close" type="button" aria-label="Schließen" style="position: absolute; top: 1rem; right: 1rem; background: white; color: black; border: none; border-radius: 4px; padding: 0.5rem 1rem; font-size: 1rem; cursor: pointer; z-index: 2;">Schließen ✕</button>
    <div id="schrift-label" style="position: absolute; top: 1rem; left: 1rem; color: white; font-size: 0.95rem; z-index: 2;"></div>
    <button id="schrift-prev" type="button" aria-label="Vorherige Schrift" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); color: black; border: none; border-radius: 50%; width: 3rem; height: 3rem; font-size: 1.7rem; line-height: 1; cursor: pointer; z-index: 2;">‹</button>
    <button id="schrift-next" type="button" aria-label="Nächste Schrift" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); color: black; border: none; border-radius: 50%; width: 3rem; height: 3rem; font-size: 1.7rem; line-height: 1; cursor: pointer; z-index: 2;">›</button>
    <img id="schrift-image" src="" alt="" style="max-width: calc(100vw - 7rem); max-height: calc(100vh - 7rem); display: block; object-fit: contain; cursor: zoom-out;" />
    <div id="schrift-fonts" style="position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: center; z-index: 2;"></div>
  </div>

  <script is:inline>
    (function () {
      const overlay = document.getElementById('schrift-lightbox');
      const img = document.getElementById('schrift-image');
      const label = document.getElementById('schrift-label');
      const closeBtn = document.getElementById('schrift-close');
      const prevBtn = document.getElementById('schrift-prev');
      const nextBtn = document.getElementById('schrift-next');
      const fontBar = document.getElementById('schrift-fonts');
      const links = Array.prototype.slice.call(document.querySelectorAll('a.schrift-preview'));
      if (!overlay || !img || !label || !closeBtn || !prevBtn || !nextBtn || !fontBar || links.length === 0) return;

      // Group thumbnails by flyer page; within a page the entries are ordered
      // by font index (0 = Original, then the alternatives) so left/right
      // steps through every font version of the same page.
      const groups = {};
      links.forEach(function (a) {
        const page = a.dataset.page;
        (groups[page] = groups[page] || []).push(a);
      });
      Object.keys(groups).forEach(function (p) {
        groups[p].sort(function (x, y) {
          return Number(x.dataset.fontIndex) - Number(y.dataset.fontIndex);
        });
      });

      let group = [];
      let current = -1;

      function fontName(a) {
        return (a.dataset.label || '').split(' · ')[0];
      }
      function render() {
        const a = group[current];
        img.src = a.dataset.hires;
        img.alt = a.dataset.label || '';
        label.textContent = (a.dataset.label || '') +
          '  (' + (current + 1) + ' / ' + group.length + ')';
        // Rebuild the font switch bar, highlighting the active version.
        fontBar.textContent = '';
        group.forEach(function (g, i) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = fontName(g);
          btn.style.cssText =
            'border: none; border-radius: 4px; padding: 0.35rem 0.7rem; ' +
            'font-size: 0.8rem; cursor: pointer; ' +
            (i === current
              ? 'background: #3e8a25; color: #222; font-weight: bold;'
              : 'background: rgba(255,255,255,0.85); color: #222;');
          btn.addEventListener('click', function (ev) {
            ev.stopPropagation();
            current = i;
            render();
          });
          fontBar.appendChild(btn);
        });
      }
      function open(a) {
        group = groups[a.dataset.page] || [a];
        current = group.indexOf(a);
        if (current < 0) current = 0;
        render();
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      function close() {
        overlay.style.display = 'none';
        img.src = '';
        document.body.style.overflow = '';
      }
      function step(delta) {
        current = (current + delta + group.length) % group.length;
        render();
      }

      links.forEach(function (a) {
        a.addEventListener('click', function (ev) { ev.preventDefault(); open(a); });
      });
      closeBtn.addEventListener('click', function (ev) { ev.stopPropagation(); close(); });
      prevBtn.addEventListener('click', function (ev) { ev.stopPropagation(); step(-1); });
      nextBtn.addEventListener('click', function (ev) { ev.stopPropagation(); step(1); });
      overlay.addEventListener('click', function (ev) {
        if (ev.target === overlay || ev.target === img) close();
      });
      document.addEventListener('keydown', function (ev) {
        if (overlay.style.display === 'none') return;
        if (ev.key === 'Escape') close();
        else if (ev.key === 'ArrowLeft') step(-1);
        else if (ev.key === 'ArrowRight') step(1);
      });

      // Touch swipe (mobile): a horizontal drag over 40px switches font.
      let startX = null, startY = null;
      overlay.addEventListener('touchstart', function (ev) {
        startX = ev.changedTouches[0].clientX;
        startY = ev.changedTouches[0].clientY;
      }, { passive: true });
      overlay.addEventListener('touchend', function (ev) {
        if (startX === null) return;
        const dx = ev.changedTouches[0].clientX - startX;
        const dy = ev.changedTouches[0].clientY - startY;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          step(dx < 0 ? 1 : -1);
        }
        startX = startY = null;
      }, { passive: true });
    })();
  </script>
</Base>
