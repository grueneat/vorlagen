---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('templates');
  // Group by category id
  const cats = new Map<string, { label: string; items: typeof all }>();
  for (const t of all) {
    const id = t.data.category ?? 'other';
    const label = t.data.category_label ?? 'Sonstige';
    if (!cats.has(id)) cats.set(id, { label, items: [] });
    cats.get(id)!.items.push(t);
  }
  return [...cats.entries()].map(([id, g]) => ({
    params: { category: id },
    props: { categoryId: id, categoryLabel: g.label, items: g.items },
  }));
}

const { categoryId, categoryLabel, items } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

items.sort((a: any, b: any) =>
  (a.data.variant_label ?? a.data.title).localeCompare(b.data.variant_label ?? b.data.title)
);
---
<Base title={`${categoryLabel} — Vorlagen-Galerie`}>
  <Breadcrumb items={[
    { label: 'Galerie', href: url('/') },
    { label: categoryLabel },
  ]} />
  <h1>{categoryLabel}</h1>
  <p style="color: var(--gat-web-text-mute);">{items.length} {items.length === 1 ? 'Variante' : 'Varianten'}</p>

  <div class="app-card-grid">
    {items.map((t: any) => {
      const preview = t.data._previews?.[0]?.src;
      const label = t.data.variant_label ?? t.data.title;
      return (
        <a href={url(`templates/${t.id}/`)} class="app-card">
          {preview && (
            <div class="app-card__media">
              <img src={url(preview)} alt={label} loading="lazy" />
            </div>
          )}
          <div class="app-card__body">
            <h3>{label}</h3>
            {t.data.format && (
              <span class="app-card__meta">
                {t.data.format}{t.data.pages ? ` · ${t.data.pages} Seiten` : ''}
              </span>
            )}
            {t.data.type === 'family' && (
              <span class="app-card__meta">Familie · {t.data.sizes?.length} Größen</span>
            )}
            {t.data.description && (
              <p style="margin: 0.5rem 0 0 0; color: var(--gat-web-text-mute); font-size: 0.9em;">{t.data.description}</p>
            )}
          </div>
        </a>
      );
    })}
  </div>
</Base>
