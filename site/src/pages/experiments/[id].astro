---
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  if (experiments.length === 0) {
    // Astro requires at least one path; emit a sentinel so the route
    // type-checks even before any experiment manifest is rendered.
    return [{ params: { id: 'placeholder' }, props: { exp: null } }];
  }
  return experiments.map((e) => ({
    params: { id: e.data.id },
    props: { exp: e },
  }));
}

const { exp } = Astro.props;

const BASE = import.meta.env.BASE_URL;
const url = (p: string) => BASE + p.replace(/^\//, '');

const expId = exp ? exp.data.id : 'placeholder';
const subject = exp ? exp.data.subject : 'placeholder';
const hypotheses: any[] = exp && Array.isArray(exp.data.hypotheses)
  ? exp.data.hypotheses
  : [];
const llms: string[] = exp && Array.isArray(exp.data.contributing_llms)
  ? exp.data.contributing_llms
  : [];

// Embed the variant data as JSON for the client script. We only need
// the slug + name + axes + rationale + preview paths.
const variantsForJs = hypotheses.map((h) => ({
  slug: h.slug,
  name: h.name || h.slug,
  axis_commitments: h.axis_commitments || [],
  rationale: h.rationale || '',
  expected_outcome: h.expected_outcome || '',
  wildcard: !!h.wildcard,
  thumb: h._previews?.thumb
    ? url(h._previews.thumb)
    : url(`/experiments/${expId}/${h.slug}/page-01.png`),
  hires: h._previews?.hires
    ? url(h._previews.hires)
    : url(`/experiments/${expId}/${h.slug}/page-01-hires.png`),
}));
---
<Base title={`Voting — ${subject}`}>
  <p><a href={url('experiments/')}>← Alle Experimente</a></p>

  {!exp && (
    <p>Kein Experiment hier. Lege eines an mit <code>bin/experiment-render</code>.</p>
  )}

  {exp && (
    <>
      <h1 class="gat-headline">{subject}</h1>
      <p class="app-meta">
        <code>{expId}</code> · {hypotheses.length} Hypothesen · LLMs: {llms.join(', ')}
      </p>
      <p>{exp.data.target_weak_area}</p>

      <div id="exp-banner" class="gat-callout gat-callout--warn" style="display: none;">
        <p style="margin: 0;">
          <strong>localStorage nicht persistent.</strong> Dein Browser speichert keine Stimmen
          zwischen Reloads (Privatmodus o. ä.). Exportiere deine Stimmen häufig über den Export-Knopf.
        </p>
      </div>

      <div class="app-exp-toolbar">
        <label>
          Rater:
          <input id="exp-rater" type="text" value="anonymous" class="app-rater-input" />
        </label>
        <button id="exp-mode-rank" type="button" class="exp-mode-btn app-mode-btn">Rank</button>
        <button id="exp-mode-direct" type="button" class="exp-mode-btn app-mode-btn">Direkt-Pick</button>
        {/*
          Issue #33: the legacy "Export JSON" toolbar button was the only
          submission path in v1 of the voting page. Phone review showed no
          casual voter would download a file and email it back, so it was
          replaced by the email + copy + inline-view trio below. The
          download button is retained ONLY behind `?dev=1` for debugging.
        */}
        <button id="exp-export" type="button" class="app-mode-btn app-mode-btn--dev" style="display: none;">
          Export JSON (dev)
        </button>
      </div>

      <section id="exp-rank" class="exp-mode" style="display: none;">
        <h2 class="gat-headline">Rank</h2>
        <p style="color: var(--gat-web-text-soft);">
          Klicke das Häkchen oben rechts auf einer Variante, um sie der Rangliste hinzuzufügen.
          Sortiere die Rangliste mit Drag-Drop (Griff <code>⋮⋮</code>) oder den Pfeiltasten ▲/▼.
          Bild-Klick öffnet weiterhin das Lightbox.
        </p>
        <!--
          Variant-card markup (JS-rendered; the literal shape is below for
          grep/audit visibility). Issue #126 Phase 2: app-Namespace.

          <div class="app-variant-card" data-slug="<slug>">
            <img src="<thumb>" />
            <button class="app-checkmark" aria-label="Select <slug>" aria-pressed="false" type="button">
              <span class="app-checkmark-visual" aria-hidden="true"></span>
              <span class="app-position-badge" aria-hidden="true" hidden></span>
            </button>
            <strong>title</strong>
          </div>
        -->
        <div id="exp-rank-grid" class="app-variant-grid"></div>

        <h3 class="gat-headline" style="margin-top: 2rem;">Deine Rangliste</h3>
        <ol id="ranked-list" class="app-ranked-list" aria-label="Your ranked choices"></ol>
        <p class="app-rank-empty" id="rank-empty">
          Noch keine Variante in der Rangliste — klicke ein Häkchen, um zu starten.
        </p>

        <!--
          Issue #33: three submission paths sharing one body string built
          once per session. `#vote-email` opens the rater's email client
          via `mailto:` (works on iOS Safari + Android Chrome). `#vote-copy`
          copies the same body to clipboard for paste-into-anything
          (WhatsApp, Signal, iMessage). `#vote-body-display` is the
          inline read-only view (rater can screenshot or copy by hand).
          All three are populated by `buildVoteBody(session)` defined in
          the rank-mode bundled script below.

          The legacy `#export-rank` JSON-download button is retained but
          hidden by default; toggled visible by `?dev=1` URL param.
        -->
        <div class="app-vote-submission">
          <div class="app-vote-actions">
            <button id="vote-email" type="button" class="app-vote-btn app-vote-btn--primary">
              Per E-Mail senden
            </button>
            <button id="vote-copy" type="button" class="app-vote-btn">
              In Zwischenablage kopieren
            </button>
          </div>
          <details class="app-vote-details">
            <summary>Stimme als Text ansehen</summary>
            <pre id="vote-body-display" class="app-vote-body" readonly aria-readonly="true"></pre>
          </details>
          {/*
            DS v2.2: ein Toast in einer .gat-toaster-Region. Bleibt im
            Layout-Fluss (display:none default) und wird bei Bedarf von
            showToast() ein-/ausgeblendet; Variante landet per className:
            .gat-toast--success | .gat-toast--error. App-Pendant
            (.app-toast --ok|--error) war Platzhalter bis DS v2.2.
          */}
          <div class="gat-toaster">
            <div id="vote-toast" class="gat-toast" role="status" aria-live="polite" style="display: none;">
              <div id="vote-toast-body" class="gat-toast__body"></div>
            </div>
          </div>
        </div>

        <button id="export-rank" type="button" class="app-mode-btn app-mode-btn--dev" style="display: none;">
          Export ranking JSON (dev)
        </button>
      </section>

      <section id="exp-direct" class="exp-mode" style="display: none;">
        <h2 class="gat-headline">Direct-Pick</h2>
        <p style="color: var(--gat-web-text-soft);">Klicke den Stern auf einer Variante um sie als Favorit zu markieren.</p>
        <div id="exp-direct-grid" class="app-variant-grid"></div>
      </section>

      <div id="rank-live-region" aria-live="polite" aria-atomic="true" class="app-sr-only"></div>

      {/* Rank-mode styles: vollständig nach src/styles/app.css migriert
          (App-Namespace .app-variant-*, .app-checkmark*, .app-ranked-*,
          .app-rank-empty, .app-drag-handle). Issue #126 Phase 2. */}

      <!-- Shared lightbox component (#126 Phase 2). Variant cards öffnen
           den Dialog programmatisch via window.expLightbox.open() weil die
           Karten zur Laufzeit aus JSON gerendert werden (keine statischen
           [data-lightbox-target]-Trigger im DOM). -->
      <Lightbox id="exp-lightbox" />

      <script id="exp-data" type="application/json" set:html={JSON.stringify({
        expId,
        variants: variantsForJs,
      })} />

      <script is:inline>
        (function () {
          var dataEl = document.getElementById('exp-data');
          if (!dataEl || !dataEl.textContent) return;
          var DATA = JSON.parse(dataEl.textContent);
          var EXP_ID = DATA.expId;
          var VARIANTS = DATA.variants;
          var STORAGE_KEY = 'experiment:' + EXP_ID + ':session:v1';

          // ---- Storage helpers (with non-persistence detection) ----
          var storageOK = (function () {
            try {
              localStorage.setItem('__exp_test', '1');
              localStorage.removeItem('__exp_test');
              return true;
            } catch (e) { return false; }
          })();
          if (!storageOK) {
            var banner = document.getElementById('exp-banner');
            if (banner) banner.style.display = 'block';
          }

          function loadSession() {
            try {
              var raw = localStorage.getItem(STORAGE_KEY);
              if (!raw) return null;
              return JSON.parse(raw);
            } catch (e) { return null; }
          }
          function saveSession(s) {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); }
            catch (e) { /* swallow — banner already up */ }
          }

          var nowISO = function () { return new Date().toISOString(); };
          var session = loadSession() || {
            rater: 'anonymous',
            session_start: nowISO(),
            direct_picks: [],
          };

          // Rater field
          var raterInput = document.getElementById('exp-rater');
          if (raterInput) {
            raterInput.value = session.rater || 'anonymous';
            raterInput.addEventListener('change', function () {
              session.rater = raterInput.value || 'anonymous';
              saveSession(session);
            });
          }

          // ---- Direct-pick rendering ----
          var directGrid = document.getElementById('exp-direct-grid');

          function renderDirect() {
            if (!directGrid) return;
            directGrid.innerHTML = '';
            VARIANTS.forEach(function (v) {
              // Issue #126 Phase 2: Inline-Styles aus dem JS-Builder
              // verschwunden, statt dessen .app-direct-card-Familie aus app.css.
              var card = document.createElement('div');
              card.className = 'app-direct-card';

              var img = document.createElement('img');
              img.src = v.thumb;
              img.alt = v.name;
              img.loading = 'lazy';
              img.className = 'app-direct-card__img';
              img.addEventListener('click', function () {
                openLightbox(v.hires, v.name);
              });
              card.appendChild(img);

              var title = document.createElement('div');
              title.className = 'app-direct-card__title';
              var star = document.createElement('button');
              star.type = 'button';
              var picked = (session.direct_picks || []).indexOf(v.slug) >= 0;
              star.textContent = picked ? '★' : '☆';
              star.setAttribute('aria-label', picked ? 'Favorit entfernen' : 'Als Favorit markieren');
              star.className = 'app-direct-card__star' + (picked ? ' app-direct-card__star--picked' : '');
              star.addEventListener('click', function () {
                var picks = session.direct_picks || (session.direct_picks = []);
                var idx = picks.indexOf(v.slug);
                if (idx >= 0) picks.splice(idx, 1);
                else picks.push(v.slug);
                saveSession(session);
                renderDirect();
              });
              title.appendChild(star);
              var nameEl = document.createElement('strong');
              nameEl.textContent = v.name;
              title.appendChild(nameEl);
              card.appendChild(title);

              if (v.wildcard) {
                var wild = document.createElement('span');
                wild.textContent = 'WILDCARD';
                wild.className = 'app-direct-card__wildcard';
                card.appendChild(wild);
              }

              if (v.axis_commitments && v.axis_commitments.length) {
                var axes = document.createElement('div');
                axes.className = 'app-direct-card__axes';
                axes.textContent = v.axis_commitments.join(' · ');
                card.appendChild(axes);
              }

              if (v.rationale) {
                var rat = document.createElement('p');
                rat.textContent = v.rationale;
                rat.className = 'app-direct-card__rationale';
                card.appendChild(rat);
              }

              directGrid.appendChild(card);
            });
          }

          // ---- Mode toggling ----
          // Note: rank-mode JS lives in a separate bundled <script> block;
          // this is-inline block only owns the direct-pick path.
          var directSection = document.getElementById('exp-direct');
          var rankSection = document.getElementById('exp-rank');
          function setMode(mode) {
            if (directSection) directSection.style.display = mode === 'direct' ? 'block' : 'none';
            if (rankSection) rankSection.style.display = mode === 'rank' ? 'block' : 'none';
            document.body.dataset.expMode = mode;
          }
          var directBtn = document.getElementById('exp-mode-direct');
          if (directBtn) directBtn.addEventListener('click', function () { setMode('direct'); });
          var rankBtn = document.getElementById('exp-mode-rank');
          if (rankBtn) rankBtn.addEventListener('click', function () { setMode('rank'); });

          // ---- Keyboard ----
          document.addEventListener('keydown', function (ev) {
            if (document.activeElement && document.activeElement.tagName === 'INPUT') return;
            if (ev.key.toLowerCase() === 'e') doExport();
          });

          // ---- Export ----
          // Direct-pick branch only; rank-mode export lives in the
          // bundled <script> (it owns its own button, #export-rank).
          // Mode-aware: if the user is currently in direct-pick mode,
          // this exports direct-pick selections. Rank exports go
          // through the bundled handler.
          function doExport() {
            session.session_end = nowISO();
            session.rater = (raterInput && raterInput.value) || session.rater || 'anonymous';
            var payload = {
              experiment_id: EXP_ID,
              rater: session.rater,
              started_at: session.session_start,
              exported_at: session.session_end,
              mode: 'direct-pick',
              selections: session.direct_picks || [],
            };
            var blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
            var href = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = href;
            var ts = new Date().toISOString().replace(/[:.]/g, '-');
            a.download = (session.rater || 'anonymous') + '-' + EXP_ID + '-' + ts + '.json';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(href);
          }
          var exportBtn = document.getElementById('exp-export');
          if (exportBtn) exportBtn.addEventListener('click', doExport);

          // ---- Lightbox (geteilte Komponente, Issue #126 Phase 2) ----
          // Backdrop-Klick / Esc / focus-trap kommen vom <dialog>-Element;
          // wir öffnen nur programmatisch über die `openAt()`-API.
          var lightboxDialog = document.getElementById('exp-lightbox');
          function openLightbox(href, text) {
            if (!lightboxDialog || !lightboxDialog.__lightbox) return;
            lightboxDialog.__lightbox.openAt(href, text);
          }

          // ---- Boot ----
          // Default to rank mode when ≥3 variants (CONTEXT decision 2);
          // direct-pick otherwise (rank doesn't add value with <3 cards).
          renderDirect();
          var defaultMode = VARIANTS.length >= 3 ? 'rank' : 'direct';
          setMode(defaultMode);
        })();
      </script>

      <!--
        Rank-mode rendering lives in a bundled <script> block so it can
        `import Sortable from 'sortablejs'` (T08+). Astro/Vite bundles
        only the non-inline block; the lightbox + direct-pick blocks
        above stay as is:inline IIFEs.
      -->
      <script>
        import Sortable from 'sortablejs';

        (function rankMode() {
          var dataEl = document.getElementById('exp-data');
          if (!dataEl || !dataEl.textContent) return;
          var DATA = JSON.parse(dataEl.textContent);
          var EXP_ID = DATA.expId;
          var VARIANTS = DATA.variants;
          var STORAGE_KEY = 'experiment:' + EXP_ID + ':session:v2:rank';

          var grid = document.getElementById('exp-rank-grid');
          var rankedList = document.getElementById('ranked-list');
          var rankEmpty = document.getElementById('rank-empty');
          var liveRegion = document.getElementById('rank-live-region');
          var exportBtn = document.getElementById('export-rank');
          var raterInput = document.getElementById('exp-rater');

          // Issue #33: email/copy/inline-view controls (rank mode only).
          var emailBtn = document.getElementById('vote-email');
          var copyBtn = document.getElementById('vote-copy');
          var bodyDisplay = document.getElementById('vote-body-display');
          var toastEl = document.getElementById('vote-toast');

          // ---- Submission constants (issue #33) -----------------------
          // Hardcoded recipient per ISSUE.md; could later be overridden
          // per-experiment via `manifest.yml::submission.email_to`.
          var EMAIL_RECIPIENT = 'florian.motlik@gruene.at';

          // ---- ?dev=1 unhides legacy JSON-download buttons ------------
          (function applyDevMode() {
            try {
              var qs = new URLSearchParams(window.location.search);
              if (qs.get('dev') === '1') {
                if (exportBtn) exportBtn.style.display = '';
                var toolbarExport = document.getElementById('exp-export');
                if (toolbarExport) toolbarExport.style.display = '';
              }
            } catch (e) { /* old browsers w/o URLSearchParams — skip */ }
          })();

          // ---- State ---------------------------------------------------
          var ranking = [];           // ordered slug array
          var startedAt = null;       // ISO timestamp on first interaction
          var sortableInstance = null;

          var slugToVariant = {};
          VARIANTS.forEach(function (v) { slugToVariant[v.slug] = v; });

          // ---- localStorage --------------------------------------------
          // v1 cleanup: scan for stale `experiment:*:session:v1:*` keys,
          // log once, delete. Silent migration per CONTEXT decision 14.
          (function clearV1Keys() {
            try {
              var toRemove = [];
              for (var i = 0; i < localStorage.length; i++) {
                var k = localStorage.key(i);
                if (!k) continue;
                if (/^experiment:.+:session:v1(:.+)?$/.test(k)) {
                  toRemove.push(k);
                }
              }
              toRemove.forEach(function (k) {
                console.log('Migrating from v1 schema — clearing stale key:', k);
                localStorage.removeItem(k);
              });
            } catch (e) { /* localStorage may be blocked; banner handled in inline block */ }
          })();

          function loadStored() {
            try {
              var raw = localStorage.getItem(STORAGE_KEY);
              if (!raw) return null;
              return JSON.parse(raw);
            } catch (e) { return null; }
          }

          function persistRanking() {
            try {
              localStorage.setItem(STORAGE_KEY, JSON.stringify({
                started_at: startedAt,
                ranking: ranking,
              }));
            } catch (e) { /* swallow — banner already up */ }
          }

          var stored = loadStored();
          if (stored && Array.isArray(stored.ranking)) {
            // Keep only slugs we still know about; drop anything stale.
            ranking = stored.ranking.filter(function (s) {
              return Object.prototype.hasOwnProperty.call(slugToVariant, s);
            });
            startedAt = stored.started_at || new Date().toISOString();
          }
          if (!startedAt) startedAt = new Date().toISOString();

          // ---- Rater-name sanitization (mirrors export filename rule) -
          function sanitizeRater(name) {
            var trimmed = (name || '').toLowerCase();
            // Allowlist [a-z0-9_-]; map anything else to '-'.
            return trimmed.replace(/[^a-z0-9_-]/g, '-');
          }

          // ---- Live region announcement helper -------------------------
          function announce(text) {
            if (!liveRegion) return;
            liveRegion.textContent = text;
          }

          function announceMove(slug, oldIndex, newIndex, total) {
            announce(
              "Moved '" + slug + "' from position " + (oldIndex + 1) +
              " to " + (newIndex + 1) + " of " + total
            );
          }

          // ---- Render variant grid (with checkmark buttons) ------------
          function renderRankGrid() {
            if (!grid) return;
            grid.innerHTML = '';
            VARIANTS.forEach(function (v) {
              var card = document.createElement('div');
              card.className = 'app-variant-card';
              card.dataset.slug = v.slug;

              var img = document.createElement('img');
              img.src = v.thumb;
              img.alt = v.name;
              img.loading = 'lazy';
              img.addEventListener('click', function () {
                // Image-click opens lightbox (parity with direct-pick block).
                // Geteilte Komponente (Issue #126 Phase 2).
                var lb = document.getElementById('exp-lightbox');
                if (lb && lb.__lightbox) lb.__lightbox.openAt(v.hires, v.name || '');
              });
              card.appendChild(img);

              var title = document.createElement('strong');
              title.textContent = v.name;
              title.style.display = 'block';
              title.style.marginTop = '0.5rem';
              card.appendChild(title);

              var checkmark = document.createElement('button');
              checkmark.type = 'button';
              checkmark.className = 'app-checkmark';
              checkmark.setAttribute('aria-label', 'Select ' + v.slug);
              checkmark.setAttribute('aria-pressed', 'false');

              var checkVisual = document.createElement('span');
              checkVisual.className = 'app-checkmark-visual';
              checkVisual.setAttribute('aria-hidden', 'true');
              checkmark.appendChild(checkVisual);

              var positionBadge = document.createElement('span');
              positionBadge.className = 'app-position-badge';
              positionBadge.setAttribute('aria-hidden', 'true');
              positionBadge.hidden = true;
              checkmark.appendChild(positionBadge);

              // Defensive stopPropagation — the click listener is attached
              // to the sibling <img>, not a parent, so bubble-through is
              // architecturally impossible (pitfall #1) but we still call
              // stopPropagation for belt-and-suspenders.
              checkmark.addEventListener('click', function (ev) {
                ev.stopPropagation();
                toggleSlug(v.slug);
              });

              card.appendChild(checkmark);
              grid.appendChild(card);
            });
          }

          function toggleSlug(slug) {
            var idx = ranking.indexOf(slug);
            if (idx >= 0) {
              ranking.splice(idx, 1);
              announce("Removed '" + slug + "' from ranking");
            } else {
              ranking.push(slug);
              announce("Added '" + slug + "' to ranking at position " + ranking.length);
            }
            refreshRankUI();
            persistRanking();
          }

          // ---- Ranked-list rendering -----------------------------------
          function buildRankedRow(slug, idx, total) {
            var v = slugToVariant[slug];
            var li = document.createElement('li');
            li.className = 'app-ranked-row';
            li.dataset.slug = slug;

            var dragHandle = document.createElement('span');
            dragHandle.className = 'app-drag-handle';
            dragHandle.setAttribute('aria-hidden', 'true');
            dragHandle.textContent = '⋮⋮';
            li.appendChild(dragHandle);

            var arrowUp = document.createElement('button');
            arrowUp.type = 'button';
            arrowUp.className = 'app-arrow-up';
            arrowUp.setAttribute('aria-label', "Move '" + slug + "' up");
            arrowUp.textContent = '▲';
            arrowUp.disabled = idx === 0;
            arrowUp.addEventListener('click', function (ev) {
              ev.stopPropagation();
              moveSlug(slug, -1);
            });
            li.appendChild(arrowUp);

            var arrowDown = document.createElement('button');
            arrowDown.type = 'button';
            arrowDown.className = 'app-arrow-down';
            arrowDown.setAttribute('aria-label', "Move '" + slug + "' down");
            arrowDown.textContent = '▼';
            arrowDown.disabled = idx === total - 1;
            arrowDown.addEventListener('click', function (ev) {
              ev.stopPropagation();
              moveSlug(slug, +1);
            });
            li.appendChild(arrowDown);

            var thumb = document.createElement('img');
            thumb.className = 'app-thumbnail';
            thumb.src = v ? v.thumb : '';
            thumb.alt = '';
            thumb.setAttribute('aria-hidden', 'true');
            li.appendChild(thumb);

            var titleEl = document.createElement('span');
            titleEl.className = 'app-title';
            titleEl.textContent = v ? v.name : slug;
            li.appendChild(titleEl);

            var removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'app-remove-btn';
            removeBtn.setAttribute('aria-label', "Remove '" + slug + "' from ranking");
            removeBtn.textContent = '×';
            removeBtn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              removeSlug(slug);
            });
            li.appendChild(removeBtn);

            return li;
          }

          function refreshRankUI() {
            // Update each card's checkmark + position-badge.
            if (grid) {
              var cards = grid.querySelectorAll('.app-variant-card');
              cards.forEach(function (card) {
                var slug = card.dataset.slug;
                var pos = ranking.indexOf(slug);
                var checkmark = card.querySelector('.app-checkmark');
                if (!checkmark) return;
                var badge = checkmark.querySelector('.app-position-badge');
                if (pos >= 0) {
                  checkmark.setAttribute('aria-pressed', 'true');
                  if (badge) {
                    badge.textContent = String(pos + 1);
                    badge.hidden = false;
                  }
                } else {
                  checkmark.setAttribute('aria-pressed', 'false');
                  if (badge) {
                    badge.textContent = '';
                    badge.hidden = true;
                  }
                }
              });
            }

            // Rebuild the ranked list.
            if (rankedList) {
              rankedList.innerHTML = '';
              ranking.forEach(function (slug, idx) {
                rankedList.appendChild(buildRankedRow(slug, idx, ranking.length));
              });
            }
            if (rankEmpty) {
              rankEmpty.style.display = ranking.length === 0 ? 'block' : 'none';
            }

            // Re-init Sortable: destroy the old instance and attach fresh
            // (the <ol> rows are a brand-new DOM each refresh). Choice
            // documented in EXECUTION.md.
            attachSortable();

            // Issue #33: keep the inline body view in sync with the
            // ranking. Called on every change (toggle, move, remove,
            // drag-drop). Cheap — just a stringify.
            refreshBodyDisplay();
          }

          // ---- Arrow-button reorder ------------------------------------
          function moveSlug(slug, delta) {
            var oldIdx = ranking.indexOf(slug);
            if (oldIdx < 0) return;
            var newIdx = oldIdx + delta;
            if (newIdx < 0 || newIdx >= ranking.length) return;
            ranking.splice(oldIdx, 1);
            ranking.splice(newIdx, 0, slug);
            refreshRankUI();
            persistRanking();
            announceMove(slug, oldIdx, newIdx, ranking.length);
          }

          function removeSlug(slug) {
            var oldIdx = ranking.indexOf(slug);
            if (oldIdx < 0) return;
            ranking.splice(oldIdx, 1);
            refreshRankUI();
            persistRanking();
            announce("Removed '" + slug + "' from position " + (oldIdx + 1));
          }

          // ---- SortableJS (drag-drop reorder) --------------------------
          function attachSortable() {
            if (!rankedList) return;
            if (sortableInstance) {
              sortableInstance.destroy();
              sortableInstance = null;
            }
            sortableInstance = new Sortable(rankedList, {
              handle: '.app-drag-handle',
              filter: '.app-arrow-up,.app-arrow-down,.app-remove-btn',
              preventOnFilter: true,
              animation: 150,
              delay: 150,
              delayOnTouchOnly: true,
              touchStartThreshold: 5,
              onEnd: function (evt) {
                var oldIndex = evt.oldIndex;
                var newIndex = evt.newIndex;
                if (oldIndex === newIndex) return;
                // Read the new order from the DOM (Sortable already
                // mutated it); rebuild `ranking` from data-slug attrs.
                var newRanking = [];
                rankedList.querySelectorAll('.app-ranked-row').forEach(function (li) {
                  newRanking.push(li.dataset.slug);
                });
                ranking = newRanking;
                persistRanking();
                announceMove(evt.item.dataset.slug, oldIndex, newIndex, ranking.length);
                // Re-render so arrow up/down disabled state and badges
                // reflect the new positions.
                refreshRankUI();
              },
            });
          }

          // ---- Body-string builder (issue #33) -------------------------
          // Single source of truth for what every submission path sends:
          // human-readable numbered ranking + identity + ISO timestamp +
          // machine-readable JSON between VOTE-JSON-START/VOTE-JSON-END
          // markers. The JSON shape is BYTE-IDENTICAL to what the legacy
          // download button produces, so the aggregator's email parser
          // (tools/experiment_results.py --from-emails) can validate
          // each extracted block against results.schema.yaml.
          //
          // `slugMap` is `slugToVariant` from the enclosing scope; we
          // pass it explicitly so the function reads as a pure builder.
          function buildVoteBody(sess, slugMap) {
            var rater = sess.rater || 'anonym';
            var when = sess.exported_at || new Date().toISOString();
            var ranking = sess.ranking || [];

            var lines = [];
            lines.push('Hi Flo,');
            lines.push('');
            lines.push("Here's my ranking for " + EXP_ID + ':');
            lines.push('');
            if (ranking.length === 0) {
              lines.push('  (no variants ranked yet)');
            } else {
              ranking.forEach(function (slug, i) {
                var v = slugMap[slug];
                var label = (v && v.name) ? v.name : slug;
                // pad rank to 2 chars so list aligns visually
                var rank = String(i + 1);
                if (rank.length < 2) rank = ' ' + rank;
                lines.push(' ' + rank + '. ' + label + '  (' + slug + ')');
              });
            }
            lines.push('');
            lines.push('— ' + rater);
            lines.push(when);
            lines.push('');
            lines.push('──────────  machine-readable, please don\'t edit  ──────────');
            lines.push('VOTE-JSON-START');
            // Same JSON shape doExportRank() produces; kept in sync below.
            var payload = {
              experiment_id: EXP_ID,
              rater: rater,
              started_at: sess.started_at || startedAt,
              exported_at: when,
              mode: 'rank',
              ranking: ranking,
            };
            lines.push(JSON.stringify(payload));
            lines.push('VOTE-JSON-END');
            return lines.join('\n');
          }

          function currentSession() {
            var raterRaw = (raterInput && raterInput.value) || 'anonymous';
            var rater = sanitizeRater(raterRaw) || 'anonymous';
            return {
              rater: rater,
              started_at: startedAt,
              exported_at: new Date().toISOString(),
              ranking: ranking,
            };
          }

          function refreshBodyDisplay() {
            if (!bodyDisplay) return;
            bodyDisplay.textContent = buildVoteBody(currentSession(), slugToVariant);
          }

          // ---- Toast helper --------------------------------------------
          // DS v2.2: .gat-toast in einer .gat-toaster-Region. Variante via
          // --success / --error. Text-Slot ist .gat-toast__body, weil die
          // DS-Komponente Icon/Body/Close trennt.
          var toastTimer = null;
          var toastBody = document.getElementById('vote-toast-body');
          function showToast(msg, kind) {
            if (!toastEl) return;
            if (toastBody) toastBody.textContent = msg;
            else toastEl.textContent = msg;
            toastEl.className = 'gat-toast ' +
              (kind === 'error' ? 'gat-toast--error' : 'gat-toast--success');
            toastEl.style.display = 'flex';
            if (toastTimer) window.clearTimeout(toastTimer);
            toastTimer = window.setTimeout(function () {
              toastEl.style.display = 'none';
            }, 4000);
          }

          // ---- Email submission (mailto:) ------------------------------
          // iOS Safari quirk: `window.location.href = mailto:...` is the
          // reliable trigger; `window.open` hits popup blockers on some
          // configs. encodeURIComponent is mandatory on both subject and
          // body — raw newlines + special chars break the mailto URI.
          function doEmail() {
            var sess = currentSession();
            var body = buildVoteBody(sess, slugToVariant);
            var subject = '[vote] ' + EXP_ID + ' — ' + (sess.rater || 'anonym');
            var url = 'mailto:' + EMAIL_RECIPIENT +
              '?subject=' + encodeURIComponent(subject) +
              '&body=' + encodeURIComponent(body);
            try {
              window.location.href = url;
              showToast('E-Mail-Client geöffnet — bitte Senden tippen.', 'ok');
            } catch (e) {
              showToast('E-Mail-Client konnte nicht geöffnet werden. Nutze die Kopier-Funktion stattdessen.', 'error');
            }
          }

          // ---- Clipboard submission ------------------------------------
          // Prefer modern Clipboard API (HTTPS/localhost only); fall back
          // to hidden-textarea + execCommand for old browsers + file://
          // local dev. If neither works (rare), surface a clear toast
          // instructing manual select+copy from the inline view.
          function doCopy() {
            var sess = currentSession();
            var body = buildVoteBody(sess, slugToVariant);

            function legacyCopy() {
              var ta = document.createElement('textarea');
              ta.value = body;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              ta.style.left = '-9999px';
              document.body.appendChild(ta);
              ta.focus();
              ta.select();
              var ok = false;
              try { ok = document.execCommand('copy'); }
              catch (e) { ok = false; }
              document.body.removeChild(ta);
              return ok;
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(body).then(
                function () { showToast('Stimme in Zwischenablage kopiert.', 'ok'); },
                function () {
                  // Permission denied / not HTTPS / iframe sandbox — try legacy
                  if (legacyCopy()) {
                    showToast('Stimme in Zwischenablage kopiert.', 'ok');
                  } else {
                    showToast('Kopieren fehlgeschlagen — markiere den Text unten manuell und kopiere ihn.', 'error');
                  }
                }
              );
            } else if (legacyCopy()) {
              showToast('Stimme in Zwischenablage kopiert.', 'ok');
            } else {
              showToast('Kopieren fehlgeschlagen — markiere den Text unten manuell und kopiere ihn.', 'error');
            }
          }

          if (emailBtn) emailBtn.addEventListener('click', doEmail);
          if (copyBtn) copyBtn.addEventListener('click', doCopy);

          // ---- Export (legacy, ?dev=1 only) ----------------------------
          function doExportRank() {
            var raterRaw = (raterInput && raterInput.value) || 'anonymous';
            var rater = sanitizeRater(raterRaw);
            if (!rater) {
              var answer = prompt('Rater name (a-z, 0-9, _-)?');
              if (answer === null) {
                console.log('Rank export cancelled by user');
                return;
              }
              rater = sanitizeRater(answer) || 'anonymous';
              if (raterInput) raterInput.value = rater;
            }
            if (ranking.length === 0) {
              console.warn('Exporting empty ranking');
            }

            var payload = {
              experiment_id: EXP_ID,
              rater: rater,
              started_at: startedAt,
              exported_at: new Date().toISOString(),
              mode: 'rank',
              ranking: ranking,
            };
            var blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
            var href = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = href;
            var ymd = new Date().toISOString().slice(0, 10); // YYYY-MM-DD
            a.download = rater + '-' + EXP_ID + '-rank-' + ymd + '.json';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(href);
          }

          if (exportBtn) exportBtn.addEventListener('click', doExportRank);

          // Issue #33: rater-name edits should re-render the body view
          // (the salutation includes the rater). The inline IIFE block
          // above ALSO listens on this input for direct-pick session
          // persistence; both handlers fire independently.
          if (raterInput) {
            raterInput.addEventListener('input', refreshBodyDisplay);
          }

          // ---- Boot ----------------------------------------------------
          renderRankGrid();
          refreshRankUI();
          refreshBodyDisplay();
        })();
      </script>
    </>
  )}
</Base>
