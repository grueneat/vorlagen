---
// Breadcrumb navigation. Each item is { label, href? } — the last item is
// the current page and is rendered without a link. Hrefs must already be
// resolved against import.meta.env.BASE_URL by the caller.
interface Crumb {
  label: string;
  href?: string;
}
const { items } = Astro.props as { items: Crumb[] };
---
<nav class="app-breadcrumb" aria-label="Brotkrümel-Navigation">
  <ol>
    {items.map((c, i) => (
      <li>
        {c.href
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page">{c.label}</span>}
        {i < items.length - 1 && <span aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
