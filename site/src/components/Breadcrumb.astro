---
// Breadcrumb navigation. Each item is { label, href? } — the last item is
// the current page and is rendered without a link. Hrefs must already be
// resolved against import.meta.env.BASE_URL by the caller.
interface Crumb {
  label: string;
  href?: string;
}
const { items } = Astro.props as { items: Crumb[] };
---
<nav aria-label="Brotkrümel-Navigation" style="margin: 0 0 1.25rem 0;">
  <ol style="list-style: none; display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem; padding: 0; margin: 0; font-size: 0.9rem;">
    {items.map((c, i) => (
      <li style="display: flex; align-items: center; gap: 0.4rem;">
        {c.href
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page" style="color: var(--muted);">{c.label}</span>}
        {i < items.length - 1 && <span aria-hidden="true" style="color: var(--muted);">›</span>}
      </li>
    ))}
  </ol>
</nav>
