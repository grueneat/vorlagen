.tmp/
build/
reports/
*.pyc
__pycache__/
.venv/
node_modules/
.DS_Store
.worktrees/

# InDesign/IDML source artifacts — never commit. Designers' source files
# live in originals/ as local-only references: .idml/.indd authoring files,
# baseline PDFs, Scribus's IDML imports (.sla), Links/ assets. They're
# inputs to tools/idml_to_dsl.py + tools/links_export.py + Phase D's
# reference_sla diff lane; the build pipeline reads them via meta.yml
# paths but the binaries themselves stay out of git.
/originals/
/originals

# Brand fonts — proprietary, never commit to public repo.
# Local copies live at /root/workspace/fonts/; they're installed into
# fontconfig during dev-container build (see Dockerfile.claude).
# Only the root-level fonts/ drop zone is blocked, not shared/fonts/
# (which holds fontconfig config files, not font binaries).
/fonts/
*.otf
*.ttf
*.ttc

# Exception: Barlow Semi Condensed (SIL-OFL) is the single print font for all
# templates. Scribus renders locally and cannot pull a webfont, so the TTFs are
# vendored here as a deliberate print-pipeline exception (same justification as
# the Vollkorn vendoring). The Dockerfile installs them into fontconfig.
!fonts/barlow-semi-condensed/*.ttf
!fonts/barlow-semi-condensed/OFL.txt

# Exception: the SIL-OFL Gotham alternatives (Issue 42) are freely
# redistributable and intentionally bundled for the font-comparison page.
!shared/fonts/alternatives/**/*.ttf

# Re-exclude Tahoma: it is proprietary (Microsoft) and must NOT be
# redistributed. The binaries live here only so the maintainer can render
# the Tahoma comparison column locally; only the raster PNG previews are
# committed (never the .ttf and never the font-embedding .pdf).
shared/fonts/alternatives/tahoma/*.ttf
site/public/schriften/tahoma/*.pdf
templates/*/fonts/tahoma/*.pdf

# The SIL-OFL alternatives are also self-hosted under site/public/fonts/ so
# the comparison page can show live web-font specimens (freely redistributable).
!site/public/fonts/**/*.ttf

# tools/links_export.py emits .pdf siblings to .ai/.psd raster outputs for
# forward-compat vector use. The SLA references the raster, not the .pdf.
# The audit (tools/asset_policy_audit.py) filters them as derived.
shared/assets/**/*.pdf
