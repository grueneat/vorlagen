#!/usr/bin/env python3
"""bin/audit-alignment — alignment-audit shim (Issue #22).

See tools/audit_alignment.py for implementation. This shim keeps the
helpers unit-testable from tools/sla_lib/tests/.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "tools"))
from audit_alignment import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
