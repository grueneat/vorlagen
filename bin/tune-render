#!/usr/bin/env python3
"""bin/tune-render — canonical re-render entry point for /idml-tune.

The Stage-2 tuning workflow re-renders a template many times. Each
re-render produces MULTIPLE artifacts that MUST stay in sync:

  1. ``templates/<slug>/template.sla``        ← from ``build.py``
  2. ``templates/<slug>/preview.pdf``         ← from ``template.sla``
  3. ``templates/<slug>/page-NN.png``         ← rasterised preview, 50 dpi
  4. ``templates/<slug>/page-NN-hires.png``   ← rasterised preview, 150 dpi
  5. ``templates/<slug>/meta.yml::previews_for_sla`` ← sha256 of template.sla
  6. ``build/<slug>/iteration.jsonl``         ← audit chain
  7. ``build/validation/<slug>/*.yml``        ← per-audit reports

Calling them individually leaves artifacts drifting out of sync — most
commonly the PNG thumbnails lagging behind preview.pdf because someone
re-rendered the SLA but forgot to rasterise. This wrapper invokes
``bin/render-gallery`` which already wires the full chain.

**The /idml-tune skill MUST call this command and only this command.**
``render_sla_to_pdf`` and ``rasterise`` from ``tools/visual_diff.py``
must NOT be called directly by the skill. The audit tools downstream
(E4/E5/E6) gate on freshness so that even if a step is bypassed, the
audits surface "STALE: …" and refuse to read drifting artifacts.

Usage:

    bin/tune-render <slug>             # render + full audit chain
    bin/tune-render <slug> --no-audit  # render only (rare; debugging)
    bin/tune-render <slug> --check     # verify in-sync; exit 1 if stale
"""
from __future__ import annotations

import argparse
import hashlib
import re
import shutil
import subprocess
import sys
from pathlib import Path

import yaml

REPO = Path(__file__).resolve().parent.parent
STAGING_ROOT = REPO / "build" / "staging"
SNAPSHOT_ROOT = REPO / "build" / "snapshot"


# Files in templates/<slug>/ that the render produces. On audit failure
# these get MOVED to build/staging/<slug>/ and the pre-render snapshot
# is restored, so a red preflight cannot pollute templates/<slug>/.
_RENDERED_ARTIFACTS = (
    "template.sla",
    "template-preview.sla",
    "preview.pdf",
    "page-01.png",
    "page-02.png",
    "page-01-hires.png",
    "page-02-hires.png",
    "per_region_history.jsonl",
    "meta.yml",  # previews_for_sla hash gets bumped on render
)


def _snapshot_template_dir(template_dir: Path, slug: str) -> Path:
    """Snapshot pre-render state to build/snapshot/<slug>-pre/.

    Returns the snapshot path. Idempotent — overwrites prior snapshot.
    """
    SNAPSHOT_ROOT.mkdir(parents=True, exist_ok=True)
    snap = SNAPSHOT_ROOT / f"{slug}-pre"
    if snap.exists():
        shutil.rmtree(snap)
    snap.mkdir(parents=True, exist_ok=True)
    for name in _RENDERED_ARTIFACTS:
        src = template_dir / name
        if src.exists():
            shutil.copy2(src, snap / name)
    return snap


def _restore_from_snapshot(template_dir: Path, snap: Path) -> None:
    """Restore the pre-render snapshot back into templates/<slug>/."""
    for name in _RENDERED_ARTIFACTS:
        src = snap / name
        dst = template_dir / name
        if src.exists():
            shutil.copy2(src, dst)
        elif dst.exists():
            # Pre-render didn't have this file (e.g. template-preview.sla
            # introduced this run); remove the new file too so the
            # template state matches pre-render exactly.
            dst.unlink()


def _move_rendered_to_staging(template_dir: Path, slug: str) -> Path:
    """Move the failed-render artifacts to build/staging/<slug>/.

    Audit reports stay in build/validation/<slug>/ (already there).
    The staging directory holds the SLA + PDF + PNGs for inspection.
    """
    STAGING_ROOT.mkdir(parents=True, exist_ok=True)
    staging = STAGING_ROOT / slug
    if staging.exists():
        shutil.rmtree(staging)
    staging.mkdir(parents=True, exist_ok=True)
    for name in _RENDERED_ARTIFACTS:
        src = template_dir / name
        if src.exists():
            shutil.copy2(src, staging / name)
    return staging


def _purge_site_mirror(slug: str) -> bool:
    """Delete the site/public mirror so the failed render can't ship."""
    mirror = REPO / "site" / "public" / "templates" / slug
    if mirror.exists():
        shutil.rmtree(mirror)
        return True
    return False


def _read_preflight(slug: str) -> tuple[bool, dict]:
    p = REPO / "build" / "validation" / slug / "preflight.yml"
    if not p.exists():
        return True, {}
    data = yaml.safe_load(p.read_text(encoding="utf-8")) or {}
    return bool(data.get("ok", True)), data


def _format_failure_directive(slug: str, preflight: dict, staging: Path) -> str:
    """Render the LLM-facing failure message."""
    failed = []
    for name, audit in (preflight.get("audits") or {}).items():
        if not audit.get("ok", True):
            detail = audit.get("detail") or f"{audit.get('issues','?')} issue(s)"
            failed.append(f"  - {name}: {detail}")
    errors = preflight.get("errors") or {}
    for k, v in errors.items():
        failed.append(f"  - phase-error/{k}: {str(v)[:200]}")
    if not failed:
        failed.append("  - (preflight.yml::ok=false but no per-audit detail)")
    return "\n".join([
        "",
        "=" * 72,
        f"  RENDER REJECTED — preflight.yml::ok = false for {slug}",
        "=" * 72,
        "",
        "  Failing audits:",
        *failed,
        "",
        "  Failed-render artifacts moved to:  build/staging/{}/".format(slug),
        "  templates/{}/ restored from pre-render snapshot.".format(slug),
        "  site/public/{}/ mirror deleted.".format(slug),
        "",
        "  No promotable preview was produced. The render cannot ship.",
        "",
        "  REQUIRED NEXT ACTION (single command — repeat until exit 0):",
        "",
        f"    bin/tune-fix {slug}",
        "",
        "  bin/tune-fix dispatches deterministic playbooks for each failing",
        "  audit (line_spacing_sim per frame, rotation reconciliation, etc.)",
        "  and re-invokes this command. Loop continues until preflight is",
        "  green (exit 0) or no playbook can advance further (exit 2).",
        "",
        "  When tune-fix exits 2 with 'ESCALATE' rows in its log, the",
        "  remaining items need a tool extension or new playbook — author",
        "  one in tools/playbooks/ and re-run, do NOT hand-patch build.py.",
        "  Hand-patches without an audit signal regress on the next render.",
        "=" * 72,
        "",
    ])


def _sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def check_freshness(template_dir: Path) -> list[str]:
    """Return list of stale-artifact complaints. Empty list = all in sync.

    The bar is "every downstream artifact is at least as new as its
    upstream input, with a 1-second slack for filesystem mtime
    granularity". Inputs:
        build.py → template.sla → preview.pdf → page-*.png
        template.sla → meta.yml::previews_for_sla (sha equality)
    """
    complaints: list[str] = []
    build_py = template_dir / "build.py"
    sla = template_dir / "template.sla"
    preview = template_dir / "preview.pdf"
    if not build_py.exists():
        complaints.append(f"missing {build_py}")
        return complaints
    bp_mtime = build_py.stat().st_mtime

    def _stale(child: Path, parent_mtime: float, tag: str) -> None:
        if not child.exists():
            complaints.append(f"missing {child.relative_to(REPO)} — run `bin/tune-render <slug>`")
        elif child.stat().st_mtime < parent_mtime - 1.0:
            complaints.append(
                f"{tag}: {child.relative_to(REPO)} is older than its source — "
                "re-render with `bin/tune-render <slug>`"
            )

    _stale(sla, bp_mtime, "template.sla")
    if sla.exists():
        sla_mtime = sla.stat().st_mtime
        _stale(preview, sla_mtime, "preview.pdf")
        if preview.exists():
            preview_mtime = preview.stat().st_mtime
            for png_name in ("page-01.png", "page-02.png",
                             "page-01-hires.png", "page-02-hires.png"):
                _stale(template_dir / png_name, preview_mtime, png_name)
            # diff-page-NN.png / composite-page-NN.png are emitted by
            # visual_diff into build/validation/<slug>/ on every render
            # (Task #50). The freshness gate checks both pages because
            # the leporello has 2 pages — keep this list in sync with
            # pages_count when adapting for other templates.
            validation_dir = (
                REPO / "build" / "validation" / template_dir.name
            )
            if validation_dir.exists():
                for diff_name in (
                    "diff-page-01.png",
                    "diff-page-02.png",
                    "composite-page-01.png",
                    "composite-page-02.png",
                ):
                    _stale(validation_dir / diff_name, preview_mtime, diff_name)
    # meta.yml hash
    meta_yml = template_dir / "meta.yml"
    if meta_yml.exists() and sla.exists():
        m = re.search(
            r"^previews_for_sla:\s*(\S+)",
            meta_yml.read_text(encoding="utf-8"),
            re.MULTILINE,
        )
        if m:
            recorded = m.group(1)
            actual = _sha256(sla)
            if recorded != actual and recorded != "_pending_first_build":
                complaints.append(
                    f"meta.yml::previews_for_sla hash {recorded[:8]}… ≠ actual {actual[:8]}… "
                    "— re-render with `bin/tune-render <slug>`"
                )
    return complaints


def rerender(slug: str, with_audit: bool) -> int:
    """Invoke render-gallery (the canonical pipeline) for one template.

    render-gallery already does: build.py → template.sla → preview.pdf →
    rasterise (with zero-padding) → meta.yml hash → sla_diff (if origin
    SLA present) → optional visual_diff → audit chain.
    """
    # Stage-2 tuning expects drift while iterating, so visual_diff runs in
    # warning-only mode: diff-page-NN.png/composite-page-NN.png still land
    # in build/validation/<slug>/ every render (Task #50), but a non-zero
    # exit doesn't halt the audit chain — the per-region audits are the
    # authoritative drift gate during tuning.
    cmd = [str(REPO / "bin" / "render-gallery"), slug, "--visual-diff-warning-only"]
    if with_audit:
        cmd.append("--audit")
    print(f"[tune-render] {' '.join(cmd)}", file=sys.stderr)
    result = subprocess.run(cmd)
    return result.returncode


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("slug", help="Template slug (directory under templates/)")
    ap.add_argument("--no-audit", action="store_true",
                    help="Render-only; skip audit chain (rare; debugging)")
    ap.add_argument("--check", action="store_true",
                    help="Verify artifacts are in sync; exit 1 if stale. Does not re-render.")
    ap.add_argument("--no-transactional", action="store_true",
                    help="Disable snapshot/restore on audit failure. "
                         "ONLY use when intentionally inspecting failed renders. "
                         "Audit failures STILL exit non-zero.")
    args = ap.parse_args(argv)

    template_dir = REPO / "templates" / args.slug
    if not template_dir.is_dir():
        sys.stderr.write(f"Template not found: {template_dir}\n")
        return 2

    if args.check:
        complaints = check_freshness(template_dir)
        if complaints:
            for c in complaints:
                sys.stderr.write(f"STALE: {c}\n")
            return 1
        print("[tune-render] all artifacts in sync", file=sys.stderr)
        return 0

    # Transactional render: snapshot pre-render state. On preflight failure
    # we restore from this snapshot so a red audit can't pollute templates/.
    snap = None
    if not args.no_audit and not args.no_transactional:
        snap = _snapshot_template_dir(template_dir, args.slug)

    rc = rerender(args.slug, with_audit=not args.no_audit)

    if args.no_audit or args.no_transactional:
        return rc

    ok, preflight = _read_preflight(args.slug)
    if ok:
        # Green render: clean up snapshot.
        if snap and snap.exists():
            shutil.rmtree(snap)
        return 0

    # Red audit: move failed-render artifacts to staging, restore snapshot,
    # purge site mirror, print directive.
    staging = _move_rendered_to_staging(template_dir, args.slug)
    if snap and snap.exists():
        _restore_from_snapshot(template_dir, snap)
        shutil.rmtree(snap)
    _purge_site_mirror(args.slug)
    sys.stderr.write(_format_failure_directive(args.slug, preflight, staging))
    return 2


if __name__ == "__main__":
    sys.exit(main())
