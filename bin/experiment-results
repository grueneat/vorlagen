#!/usr/bin/env python3
"""bin/experiment-results — vote aggregation entry point (issue #29).

See tools/experiment_results.py for implementation. This shim keeps the
helpers unit-testable from tools/sla_lib/tests/.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "tools"))
from experiment_results import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
