#!/usr/bin/env bash
# bin/validate — local round-trip validation
#
# Runs sla_diff (--strict) + visual_diff for every template under
# templates/<id>/ that has an `original_sla:` key in its meta.yml. Exits
# non-zero if any template fails either check.
#
# Usage:
#   bin/validate                # default 150 dpi (full coverage)
#   bin/validate --ci           # 96 dpi (CI parity)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

DPI=150
if [ "${1:-}" = "--ci" ]; then
    DPI=96
fi

OUT_BASE="build/validation"
mkdir -p "$OUT_BASE"

echo "=== preflight: bin/check-fontsizes ==="
if ! "$ROOT/bin/check-fontsizes"; then
    echo "preflight FAILED — fix fractional FONTSIZE in SLA before continuing" >&2
    exit 1
fi
echo "preflight: PASS"
echo

echo "=== preflight: bin/check-stale-previews ==="
if ! "$ROOT/bin/check-stale-previews"; then
    echo "preflight FAILED — gallery previews are stale; refusing to validate" >&2
    exit 1
fi
echo "preflight: PASS"
echo

EXIT=0
for tdir in templates/*/; do
    if [ ! -f "$tdir/meta.yml" ]; then
        continue
    fi
    if ! grep -q "^original_sla:" "$tdir/meta.yml"; then
        continue
    fi
    tid=$(basename "$tdir")
    original=$(python3 -c "
import os, sys, yaml
m = yaml.safe_load(open('$tdir/meta.yml'))
rel = m.get('original_sla', '')
if not rel: sys.exit('no original_sla in $tid meta.yml')
print(os.path.normpath(os.path.join('$tdir', rel)))
")
    echo "=== $tid ==="
    echo "  original: $original"
    echo "  template: ${tdir}template.sla"

    if ! python3 tools/sla_diff.py \
        --left "$original" \
        --right "${tdir}template.sla" \
        --json "$OUT_BASE/${tid}-sla_diff.json" \
        --strict \
        --allow-brand-extras > /dev/null; then
        echo "  sla_diff: FAIL"
        EXIT=1
    else
        echo "  sla_diff: PASS"
    fi

    if [ -f "${tdir}baseline.pdf" ] && [ -f "${tdir}diff.yml" ]; then
        if ! python3 tools/visual_diff.py \
            "${tdir}template.sla" \
            --baseline "${tdir}baseline.pdf" \
            --tolerance "${tdir}diff.yml" \
            --dpi "$DPI" \
            --out "$OUT_BASE/${tid}/" > /dev/null 2>&1; then
            echo "  visual_diff (${DPI}dpi): FAIL"
            EXIT=1
        else
            echo "  visual_diff (${DPI}dpi): PASS"
        fi
    else
        echo "  visual_diff: SKIPPED (no baseline.pdf or diff.yml)"
    fi
done

# bx4d8: static headline-spacing audit (no render — CI-safe). Flags
# too-tight / uneven / top-gap-collapse stacked headlines across every
# template carrying a template.sla with a stacked-headline group.
echo
echo "=== headline_spacing_audit (static) ==="
for tdir in templates/*/; do
    [ -f "${tdir}template.sla" ] || continue
    tid=$(basename "$tdir")
    if ! python3 tools/headline_spacing_audit.py \
        --slug "$tid" --templates-dir templates --static-only > /dev/null 2>&1; then
        echo "  $tid: FAIL"
        EXIT=1
    fi
done
echo "headline_spacing_audit: done"

exit $EXIT
