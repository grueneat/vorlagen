#!/usr/bin/env bash
# bin/ci-local — local mirror of the "Build & Deploy Gallery" CI build job.
#
# Runs the exact same sequence of build-job steps that
# .github/workflows/pages.yml executes, in the same order, so a developer
# can run ONE command before pushing and catch any failure CI would catch.
# "Green locally" should reliably predict "green in CI".
#
# This exists because PR #116 broke main's gallery deploy with a
# "passed locally / failed in CI" surprise: a working-tree-mutating test
# ran before bin/check-stale-previews in CI, so the staleness gate saw
# mutated files. Running the full job sequence locally surfaces exactly
# that class of step-ordering / side-effect bug.
#
# What this gate does NOT do: install system packages, pip deps, Node, or
# Scribus. Those are environment provisioning, not pass/fail checks — the
# gate verifies they are present and fails fast with an actionable message
# if not. Match the CI runner versions if a discrepancy is suspected
# (see pages.yml: Python 3.12, Node 20, Scribus 1.6.5).
#
# Usage:
#   bin/ci-local              # run the full build-job sequence
#   bin/ci-local --no-site    # skip the Astro npm build (faster iteration)
#
# Exit 0 → every build-job step passed; exit non-zero → first failure.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

RUN_SITE=1
if [ "${1:-}" = "--no-site" ]; then
    RUN_SITE=0
fi

step() { printf '\n=== %s ===\n' "$1"; }
fail() { printf 'ci-local: FAIL — %s\n' "$1" >&2; exit 1; }

# Production template SLAs are the committed source of truth — no build-job
# step may mutate them (CI's check-stale-previews validates their bytes).
# The _smoke/ fixtures and site/ gallery output are *intentionally*
# regenerated by the build job, so they are excluded from this guard.
prod_sla_hashes() {
    git ls-files 'templates/*/template.sla' 'templates/*/template-preview.sla' \
        | grep -v '^templates/_smoke/' \
        | sort \
        | while IFS= read -r f; do
              [ -f "$f" ] && printf '%s  %s\n' "$(sha256sum < "$f" | cut -d' ' -f1)" "$f"
          done
}
PROD_SLA_BEFORE="$(prod_sla_hashes)"

# --- preflight: required toolchain ----------------------------------------
step "preflight: toolchain"
command -v python3 >/dev/null 2>&1 || fail "python3 not found"
command -v scribus >/dev/null 2>&1 || \
    fail "scribus not found — gallery_build renders previews; install Scribus 1.6.5"
if [ "$RUN_SITE" -eq 1 ]; then
    command -v npm >/dev/null 2>&1 || \
        fail "npm not found — needed for the Astro site build; pass --no-site to skip"
fi
echo "preflight: PASS"

# --- mirror: pages.yml "Build smoke templates via DSL" --------------------
step "Build smoke templates via DSL"
for build in templates/_smoke/*/build.py; do
    [ -f "$build" ] && python3 "$build"
done

# --- mirror: pages.yml "Generate gallery content (PDFs + PNG previews)" ---
step "Generate gallery content (PDFs + PNG previews)"
python3 tools/gallery_build.py

# --- mirror: pages.yml "Install Astro deps" + "Build Astro site" ----------
if [ "$RUN_SITE" -eq 1 ]; then
    step "Install Astro deps"
    ( cd site && npm ci --no-audit --no-fund )

    step "Build Astro site"
    ( cd site && npm run build )
else
    step "Astro site build (SKIPPED via --no-site)"
fi

# --- mirror: pages.yml "Run unit tests" -----------------------------------
# CI runs this BEFORE check-stale-previews. A test that mutates the working
# tree here would silently poison the staleness gate below — running them
# in the same order locally reproduces exactly that failure mode.
step "Run unit tests"
python3 -m unittest discover tools/sla_lib/tests

# --- mirror: pages.yml "Validate reproductions (sla_diff + stale-previews)"
step "Validate reproductions (sla_diff + stale-previews)"
mkdir -p build/validation
python3 bin/check-stale-previews
for tdir in templates/postkarte-a6-kampagne templates/plakat-a1-hochformat templates/zeitung-a4-grun; do
    tid=$(basename "$tdir")
    read -r original strict <<<"$(python3 -c "
import os, sys, yaml
m = yaml.safe_load(open('$tdir/meta.yml'))
rel = m.get('original_sla', '')
if not rel:
    sys.exit('no original_sla in meta.yml')
print(os.path.normpath(os.path.join('$tdir', rel)),
      'true' if m.get('sla_diff_strict', True) else 'false')
")"
    if [ "$strict" != "true" ]; then
        echo "=== sla_diff $tid: SKIPPED (sla_diff_strict=false in meta.yml) ==="
        continue
    fi
    mkdir -p "build/validation/$tid"
    echo "=== sla_diff $tid ==="
    python3 tools/sla_diff.py \
        --left "$original" \
        --right "$tdir/template.sla" \
        --json "build/validation/$tid/sla_diff.json" \
        --strict \
        --allow-brand-extras
done

# --- mirror: pages.yml "Run brand validator" ------------------------------
step "Run brand validator"
for sla in templates/*/template.sla templates/*/*.sla; do
    [ -f "$sla" ] && python3 tools/check_ci.py "$sla" || true
done

# --- mirror: pages.yml "Run structural check (Issue #12)" -----------------
step "Run structural check (Issue #12)"
PYTHONPATH=tools python3 -m sla_lib.builder.structural_check --all

# --- mirror: pages.yml "Run alignment audit (informational)" --------------
step "Run alignment audit (Issue #22, informational)"
mkdir -p build/audit
PYTHONPATH=tools python3 tools/audit_alignment.py --all \
    --output-dir build/audit/ || true

# --- post-run: production template SLAs must be untouched -----------------
# The whole point of this gate. If any step above mutated a committed
# production template.sla, CI's check-stale-previews would see different
# bytes than were committed — the exact "passes locally / fails in CI"
# failure mode that motivated this script. The _smoke/ fixtures and the
# site/ gallery output are deliberately regenerated and so are excluded.
step "Production template SLAs untouched"
PROD_SLA_AFTER="$(prod_sla_hashes)"
if [ "$PROD_SLA_BEFORE" != "$PROD_SLA_AFTER" ]; then
    echo "ci-local: FAIL — a build-job step mutated a committed template.sla:" >&2
    diff <(printf '%s\n' "$PROD_SLA_BEFORE") \
         <(printf '%s\n' "$PROD_SLA_AFTER") >&2 || true
    echo "A CI step must not modify committed production SLAs; CI would diverge." >&2
    exit 1
fi
echo "Production template SLAs unchanged — no committed SLA was mutated."

printf '\nci-local: PASS — all Build & Deploy Gallery build-job steps green.\n'
