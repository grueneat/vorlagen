    <PAGEOBJECT XPOS="124.125535215552" YPOS="2587.96125983647" OwnPage="3" ItemID="100000063" PTYPE="4" WIDTH="36.2139143257324" HEIGHT="26.8731431093402" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="9.09201745282855" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="124.125535215552" gYpos="2587.96125983647" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1" ROT="0" FRTYPE="3" path="M0 0 L36.2139 0 L36.2139 26.8731 L0 26.8731 L0 0 Z" copath="M0 0 L36.2139 0 L36.2139 26.8731 L0 26.8731 L0 0 Z" ANNAME="Kopie von u2d45 (3)">
