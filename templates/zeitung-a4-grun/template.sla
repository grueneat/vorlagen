    <PAGEOBJECT XPOS="156.693543307087" YPOS="1924.18348623853" OwnPage="3" ItemID="100000009" PTYPE="4" WIDTH="154.958" HEIGHT="285.485713857498" CLIPEDIT="1" PWIDTH="1.01189873869794" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="11.999999999999998" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="156.693543307087" gYpos="1924.18348623853" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="100000010" BACKITEM="-1" ROT="0" FRTYPE="3" path="M0 0 L154.958 0 L154.958 285.486 L0 285.486 L0 0 Z" copath="M0 0 L154.958 0 L154.958 285.486 L0 285.486 L0 0 Z" ANNAME="Kopie von u2d5c (4)">
      <StoryText>
        <DefaultStyle/>
        <ITEXT CH="Perem la posseditatur "/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Aianeptas es re iliaes dolupta"/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Quaecep erfernatur adit, volut faciend estibusda pediosaes minctem oditatur? Qui as et inimus. io beat fugitatia qui od magnihi lluptam usciatio. Optatinverit am laborporrum quas atur, conet et de officte nihicab orrorrum ut debis eium endes nonsent."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Em aut vid que vellacc aborisi tatiur sunt, commolupitia as voluptas min natincium quat hilit, sit elestiasiti re ma non comnim diam is inctotat."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Haribusam alit quo doluptatem nonectiistis milit ratur aut alistori vellori debis et odi quia dit ommolor epedit hilitis qui optatus."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="On porecae. "/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Et od eseque eos alic temperaectem ratumqu iandae parum, ulpat am laborporrum quas atur, conet et de officte nihicab orr dolor aut lamusciis ideles atatem quodiatet qui consedi t ex et reiienem et ius pera cone liti auusaectem qui nem et doluptata illa pratur moluptatia sande xceper."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Magnatet, as erfero cum que maximintem est exped molestiusti audis sedem corporemped que lanto im audam adist ratius, sitatur?"/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Gentorrum eum re re dus"/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Ium rerit dolendaerest hicilig endenimped qsenis voluptas qut am laborporrum quas atur, conet et de officte niuis andi doloritatet paritati ecullitatem hillendi nonsed mm quodiatet qui consedi t ex et reiiagnihil idigenimusae et, voluptur? Quia dolupta ipident."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Ari abo. Nam unt aut ab uis andi doloritatet paritati dist, qui aligeni mendita eceribus, occullo incium utem expland."/>
        <para PARENT="Fließtext "/>
      </StoryText>
    </PAGEOBJECT>
    <PAGEOBJECT XPOS="320.156220472441" YPOS="1924.18348623853" OwnPage="3" ItemID="100000010" PTYPE="4" WIDTH="154.958" HEIGHT="285.484763682718" CLIPEDIT="1" PWIDTH="0" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="11.999999999999998" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="320.156220472441" gYpos="1924.18348623853" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="100000011" BACKITEM="100000009" ROT="0" FRTYPE="3" path="M0 0 L154.958 0 L154.958 285.485 L0 285.485 L0 0 Z" copath="M0 0 L154.958 0 L154.958 285.485 L0 285.485 L0 0 Z" ANNAME="Kopie von u2da1 (2)">
