    <PAGEOBJECT XPOS="156.692913" YPOS="1123.595387" OwnPage="1" ItemID="100000058" PTYPE="4" WIDTH="489.985356" HEIGHT="136.733944" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0.000000" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="156.692913" gYpos="1123.595387" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1" ROT="0.000000" FRTYPE="0" path="M0 0 L489.985 0 L489.985 136.734 L0 136.734 L0 0 Z" copath="M0 0 L489.985 0 L489.985 136.734 L0 136.734 L0 0 Z">
