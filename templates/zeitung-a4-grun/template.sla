    <PAGEOBJECT XPOS="156.968503" YPOS="3691.412385" OwnPage="7" ItemID="100000021" PTYPE="4" WIDTH="154.959999" HEIGHT="397.563993" CLIPEDIT="0" PWIDTH="1.011899" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="11.999999" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="156.968503" gYpos="3691.412385" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="100000022" BACKITEM="-1" ROT="0.000000" FRTYPE="3" path="M0 0 L0 397.564 L154.96 397.564 L154.96 0 L0 0 Z" copath="M0 0 L0 397.564 L154.96 397.564 L154.96 0 L0 0 Z" fillRule="0" ANNAME="Kopie von u2d5c (9)">
      <StoryText>
