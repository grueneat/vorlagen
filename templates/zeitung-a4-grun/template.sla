    <PAGEOBJECT XPOS="695.27622047226" YPOS="4429.44850392937" OwnPage="9" ItemID="100000109" PTYPE="2" WIDTH="595.275590551" HEIGHT="357.560670382556" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" PFILE="" PRFILE="sRGB display profile (ICC v2.2)" IRENDER="0" gXpos="695.27622047226" gYpos="4429.44850392937" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1" ROT="0" FRTYPE="0" path="M0 0 L595.276 0 L595.276 357.561 L0 357.561 L0 0 Z" copath="M0 0 L595.276 0 L595.276 357.561 L0 357.561 L0 0 Z" ANNAME="P9 Spread"/>
    <PAGEOBJECT XPOS="751.969133858087" YPOS="4807.48623853211" OwnPage="10" ItemID="100000030" PTYPE="4" WIDTH="154.959939529864" HEIGHT="177.552816578363" CLIPEDIT="1" PWIDTH="1.01191140411581" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="11.999999999999998" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="751.969133858087" gYpos="4807.48623853211" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="100000031" BACKITEM="-1" ROT="0" FRTYPE="3" path="M0 0 L154.96 0 L154.96 177.553 L0 177.553 L0 0 Z" copath="M0 0 L154.96 0 L154.96 177.553 L0 177.553 L0 0 Z" ANNAME="Kopie von u2d5c (14)">
      <StoryText>
        <DefaultStyle/>
        <ITEXT CH="Perem la posseditatur "/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Aianeptas es re iliaes dolupta"/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Quaecep erfernatur adit, volut faciend estibusda pediosaes minctem oditatur? Qui as et inimus. io beat fugitatia qui od magnihi lluptam usciatio. Optatinverit am laborporrum quas atur, conet et de officte nihicab orrorrum ut debis eium endes nonsent."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Em aut vid que vellacc aborisi tatiur sunt, commolupitia as voluptas min natincium quat hilit, sit elestiasiti re ma non comnim diam is inctotat."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Haribusam alit quo doluptatem nonectiistis milit ratur aut alistori vellori "/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="On porecae. "/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Et od eseque eos alic temperaectem ratumqu iandae parum, ulpat am laborporrum quas atur, conet et de officte nihicab orr dolor aut lamusciis ideles atatem quodiatet qui consedi t ex et reiienem et ius pera cone liti auusaectem qui nem et doluptata illa pratur moluptatia sande xceper."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Magnatet, as erfero cum que maximintem est exped molestiusti audis sedem corporemped que lanto im audam adist ratius, sitatur?"/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Gentorrum eum re re dus"/>
        <para PARENT="Zwischenüberschrift"/>
        <ITEXT CH="Ium rerit dolendaerest hicilig endenimped qsenis voluptas qut am laborporrum quas atur, conet et de officte niuis andi doloritatet paritati ecullitatem hillendi nonsed mm quodiatet qui consedi t ex et reiiagnihil idigenimusae et, voluptur? Quia dolupta ipident."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Ari abo. Nam unt aut ab uis andi doloritatet paritati dist, qui aligeni mendita eceribus, occullo incium utem expland."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="auusaectem qui nem et doluptata illa pratur moluptatia sande xceper."/>
        <para PARENT="Fließtext "/>
        <ITEXT CH="Magnatet, as erfero cum que maximintem est exped..."/>
        <trail PARENT="Fließtext "/>
      </StoryText>
    </PAGEOBJECT>
