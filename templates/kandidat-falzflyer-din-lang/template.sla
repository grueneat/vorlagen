      <StoryText>
        <DefaultStyle PARENT="falzflyer/teaser-body"/>
        <ITEXT CH="Mödling hat einen Klimaplan — er muss umgesetzt werden. Ich bringe Erfahrung aus 10 Jahren Energiewende-Beratung mit und will sie für unsere Gemeinde einsetzen.&#10;&#10;Drei Schwerpunkte: leistbares Wohnen, lokale Wirtschaft, Bildung vor Ort."/>
        <trail PARENT="falzflyer/teaser-body"/>
      </StoryText>
    </PAGEOBJECT>
