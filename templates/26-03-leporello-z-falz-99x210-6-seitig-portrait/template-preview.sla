    <PAGEOBJECT XPOS="147.8808503937008" YPOS="136.0807244094488" OwnPage="0" ItemID="100000013" PTYPE="4" WIDTH="184.86822047244095" HEIGHT="435.99996850393705" CLIPEDIT="0" PWIDTH="0" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="11.338582677165356" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="2" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" gXpos="147.8808503937008" gYpos="136.0807244094488" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1" ROT="0" FRTYPE="0" path="M0 0 L184.868 0 L184.868 436 L0 436 L0 0 Z" copath="M0 0 L184.868 0 L184.868 436 L0 436 L0 0 Z" ANNAME="u1c7">
      <StoryText>
        <DefaultStyle PARENT="idml/fliesstext-auf-gruenem-hintergrund"/>
        <ITEXT CH="Usapiene mporia quisin consequid que in et volor re doleceat laciisci nectur?" FONT="Gotham Narrow Book"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <ITEXT CH="Tinvend igenis ute voloria qui cus " FONT="Gotham Narrow Book"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <ITEXT CH="et ut optate vendam ilis volorias pita dis at rem et molo ipsum fuga. Et eaque volor, ipis eos sinusae di que parmquas senihicto consent, ut qui doloruptam et volorro qui optate nis eaquamus." FONT="Gotham Narrow Book"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <ITEXT CH="Lia vellam, conemporro modi tatque nii tectotmusa qui tota nis quam quis quae cum et arum vendellab voloriaspita dis quaturem. Ur, omniet vello modi aceprate pem ssi ir, sit, quatenisto optatib eaquiate rumentios quo oditibust, quis et et quaturem. Et eaque volor, ipis eosenihicto consent. Nam quatur." FONT="Gotham Narrow Book"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <para PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
        <ITEXT CH="Recum doluptae dolupissit porumquis dolut quamet faccae di aut fuga. Bit, unt quatem harum, offic te officit, que praturio eliquo maionsecto velis volut vollitatem ipitae comnim imodignatis estem quat." FONT="Gotham Narrow Book"/>
        <trail PARENT="idml/fliesstext-auf-gruenem-hintergrund" ALIGN="0"/>
      </StoryText>
    </PAGEOBJECT>
